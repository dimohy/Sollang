namespace native_tests.tests

import native_tests.math as math
import native_tests.test_support as support

# Sollang-native tests are ordinary zero-input Bool functions.
test_addition: -> Bool => math.add(20, 22) == 42
test_subtraction: -> Bool => math.subtract(44, 2) == 42
test_only_import: -> Bool => support.expected == 42
