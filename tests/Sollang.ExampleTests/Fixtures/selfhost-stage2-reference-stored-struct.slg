# A readonly reference stored in a struct keeps its owner live.
struct Pair {
    first: Int
    second: Int
}

struct PairView {
    value: ref Int
}

same value: ref Int -> ref Int {
    value
}

read value: ref Int -> Int {
    value
}

main {
    Pair { first: 10, second: 20 } => pair!
    PairView { value: pair!.first -> same } => stored
    Pair { first: 30, second: 40 } => pair!
    stored.value -> read -> println
}
