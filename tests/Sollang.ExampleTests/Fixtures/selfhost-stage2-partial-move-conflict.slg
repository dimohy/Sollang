# Verifies that Stage1 and Stage2 reject a reachable whole-owner use after one
# owned field has moved, before either compiler emits an LLVM target header.

struct Pair {
    left: [Int; ~]
    right: [Int; ~]
}

invalid: -> Int {
    Pair { left: [1, ~], right: [2, ~] } => pair!
    pair!.left => moved!
    pair! => whole!
    0
}

main { }
