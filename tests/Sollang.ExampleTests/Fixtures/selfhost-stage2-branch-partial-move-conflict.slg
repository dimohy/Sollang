# Verifies that Stage2 rejects a branch whose normal join retains a moved
# owned field, before either compiler emits an LLVM target header.

struct Pair {
    left: [Int; ~]
    right: [Int; ~]
}

invalid flag: Bool -> UIntSize {
    Pair { left: [1, ~], right: [2, ~] } => pair!
    flag -> if {
        pair!.left => moved!
    }
    pair!.right -> len
}

main { }
