# Verifies that a local helper cannot hide a mutable outer capture from the
# production parallel-callback safety check.

shift seed: Int -> [Int; ~] {
    addOffset value: Int -> Int {
        value + offset!
    }

    10 => offset!
    [1, 2, 3, ~] => values!
    values! -> parallel value {
        value -> addOffset
    } => shifted!
    shifted!
}

main {
    0 -> shift => shifted!
}
