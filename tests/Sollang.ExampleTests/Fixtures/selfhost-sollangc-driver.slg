import sollang.compiler.llvm.text as llvm
import sollang.compiler.llvm.source_root as llvmRoot
import sollang.compiler.ir.module_artifacts as moduleArtifacts
import sollang.compiler.ir.typed as typedIr
import sollang.compiler.semantic.context as semanticContext
import sollang.compiler.semantic.module_interfaces as moduleInterfaces
import sollang.compiler.semantic.module_cache as moduleCache
import sollang.compiler.semantic.module_cache_io as moduleCacheIo
import sollang.compiler.semantic.modules as modules
import sollang.compiler.semantic.type_ids as typeIds
import sys.path as path
import sys.process as process

processCode result: Result<Int, Text> -> Int => result -> when {
    Ok(code) => code
    Err(error) => -1
}

isJobsOption value: Text -> Bool {
    (value -> len) == UIntSize(6) => matches!
    matches! -> if {
        ((value -> byte(UIntSize(0))) == UInt8(45) and (value -> byte(UIntSize(1))) == UInt8(45) and (value -> byte(UIntSize(2))) == UInt8(106) and (value -> byte(UIntSize(3))) == UInt8(111) and (value -> byte(UIntSize(4))) == UInt8(98) and (value -> byte(UIntSize(5))) == UInt8(115)) => matches!
    }
    matches!
}

parsePositiveInt value: Text -> Int {
    0 => parsed!
    (value -> len) > UIntSize(0) => valid!
    UIntSize(0) => index!
    (valid! and index! < (value -> len)) -> while {
        value -> byte(index!) => digit
        (digit < UInt8(48) or digit > UInt8(57)) -> if {
            false => valid!
        } else {
            parsed! * 10 + Int(digit - UInt8(48)) => parsed!
        }
        index! + UIntSize(1) => index!
    }
    (valid! and parsed! > 0) -> if { parsed! } else { -1 }
}

configureWorkerLimit optionStart: UIntSize -> Int uses Process {
    process.arguments => arguments
    0 => workers!
    optionStart < (arguments -> len) -> if {
        arguments[optionStart] -> isJobsOption -> if {
            optionStart + UIntSize(1) < (arguments -> len) -> if {
                arguments[optionStart + UIntSize(1)] -> parsePositiveInt => requested
                requested > 0 -> if {
                    requested -> limitParallelWorkers => workers!
                } else { -1 => workers! }
            } else { -1 => workers! }
        }
    }
    workers!
}

sourceStart optionStart: UIntSize -> UIntSize uses Process {
    process.arguments => arguments
    optionStart => start!
    optionStart < (arguments -> len) -> if {
        arguments[optionStart] -> isJobsOption -> if { optionStart + UIntSize(2) => start! }
    }
    start!
}

collectPaths start: UIntSize -> [Text; ~] uses Process {
    process.arguments => arguments
    arguments -> len => argumentCount
    [Text; ~] => paths!
    start => index!
    index! < argumentCount -> while {
        arguments[index!] => path
        paths! -> push(path)
        index! + UIntSize(1) => index!
    }
    paths!
}

collectBuildPaths start: UIntSize -> [Text; ~] uses Process {
    process.arguments => arguments
    arguments -> len => argumentCount
    [Text; ~] => paths!
    start => index!
    index! < argumentCount -> while {
        arguments[index!] => path
        paths! -> push(path)
        index! + UIntSize(1) => index!
    }
    paths!
}

emitLinuxFiles pathStart: UIntSize -> Unit uses Console, File, Process {
    pathStart -> collectPaths => paths!
    paths! -> llvm.emitLinuxFiles
}

emitWasmFiles pathStart: UIntSize -> Unit uses Console, File, Process {
    pathStart -> collectPaths => paths!
    paths! -> llvm.emitWasmFiles
}

emitWindowsFiles pathStart: UIntSize -> Unit uses Console, File, Process {
    pathStart -> collectPaths => paths!
    paths! -> llvm.emitFiles
}

emitLinuxRoot pathStart: UIntSize -> Unit uses Console, File, Process {
    process.arguments => arguments
    # Root discovery and source mapping run in this native Windows driver even
    # when the emitted program targets Linux.
    arguments[pathStart] -> path.fromText(path.Style.Windows) => root!
    root! -> llvmRoot.emitLinuxRoot
}

emitWasmRoot pathStart: UIntSize -> Unit uses Console, File, Process {
    process.arguments => arguments
    arguments[pathStart] -> path.fromText(path.Style.Windows) => root!
    root! -> llvmRoot.emitWasmRoot
}

emitWindowsRoot pathStart: UIntSize -> Unit uses Console, File, Process {
    process.arguments => arguments
    arguments[pathStart] -> path.fromText(path.Style.Windows) => root!
    root! -> llvmRoot.emitRoot
}

emitFingerprints pathStart: UIntSize -> Unit uses Console, File, Process {
    pathStart -> collectPaths => paths!
    paths! -> semanticContext.prepareFiles => snapshot!
    snapshot!.package -> moduleInterfaces.fingerprintAnalyzed => fingerprints!
    0 => fingerprintIndex!
    fingerprintIndex! < (fingerprints! -> len) -> while {
        fingerprints![fingerprintIndex!] => fingerprint
        "module fingerprint = $(fingerprint.moduleHash),$(fingerprint.sourceHash),$(fingerprint.interfaceHash),$(fingerprint.implementationHash),$(fingerprint.importHash),$(fingerprint.publicSymbolCount),$(fingerprint.importCount)" -> println
        fingerprintIndex! + 1 => fingerprintIndex!
    }
}

runInterfaceCache: -> Unit uses Console, File, Process {
    process.arguments => arguments
    UIntSize(4) -> collectPaths => paths!
    paths! -> semanticContext.prepareFiles => snapshot!
    snapshot!.package -> moduleCache.encodeAnalyzed(UInt64(1)) => current!
    current! -> moduleCacheIo.publish(arguments[2], arguments[3]) => published
    arguments[2] -> moduleCacheIo.load => loaded!
    snapshot!.package -> moduleCache.reuseAnalyzed(loaded!, UInt64(1)) => reuse
    (published and reuse.status == 0) -> if { 1 } else { 0 } => persistent
    "module cache = $(reuse.status),$(reuse.hits),$(reuse.misses),$(reuse.bodyOnlyConsumerHits),$persistent" -> println
}

runModuleArtifacts: -> Unit uses Console, File, Process {
    UIntSize(2) -> collectPaths => paths!
    paths! -> semanticContext.prepareFiles => snapshot!
    snapshot! -> typedIr.lowerContext => ir!
    [typeIds.SemanticType; ~] => types!
    snapshot!.semantic.types -> each currentType { types! -> push(currentType) }
    [modules.ModuleIdentity; ~] => identities!
    snapshot!.modules -> each identity { identities! -> push(identity) }
    ir! -> moduleArtifacts.encode(identities!, types!) => words!
    words! -> moduleArtifacts.validate => validation
    words! -> moduleArtifacts.decode(identities!) => decoded!
    [typedIr.TypedIrNode; ~] => decodedIr!
    decoded!.ir -> each node { decodedIr! -> push(node) }
    decodedIr! -> len => decodedNodeCount
    (validation.nodeCount > 0 and decoded!.status == 0 and decodedNodeCount == validation.nodeCount) -> if { 1 } else { 0 } => hasNodes
    "module artifacts = $(validation.status),$(validation.moduleCount),$hasNodes" -> println
}

buildWindows pathStart: UIntSize -> Unit uses Console, File, Process {
    process.arguments => arguments
    pathStart -> collectBuildPaths => sourcePaths!
    [arguments[0], "windows", ~] => emitArgv!
    pathStart > UIntSize(5) -> if {
        emitArgv! -> push(arguments[5])
        emitArgv! -> push(arguments[6])
    }
    sourcePaths! -> each sourcePath { emitArgv! -> push(sourcePath) }
    process.RunToFileRequest {
        argv: emitArgv!
        output: arguments[2]
    } -> process.runToFile -> processCode => emitCode

    emitCode == 0 -> if {
        [arguments[4], arguments[2], "-O1", "-Wno-override-module", "-o", arguments[3], ~] => clangArgv!
        clangArgv! -> process.run -> processCode => clangCode
        clangCode >= 0 -> if {
            "native build = $(clangCode)" -> println
        } else {
            "native compiler invocation failed" -> println
        }
    } else {
        "compiler emission failed" -> println
    }
}

main {
    process.arguments => arguments
    arguments[1] -> len => targetLength
    UIntSize(2) => optionStart!
    targetLength == UIntSize(13) -> if { UIntSize(5) => optionStart! }
    optionStart! -> configureWorkerLimit => workers
    optionStart! -> sourceStart => pathStart
    workers < 0 -> if {
        "; sollang error: --jobs expects a positive integer" -> println
    } else {
    workers > 0 -> if { "; sollang workers = $workers" -> println }
    targetLength == UIntSize(16) -> if {
        runModuleArtifacts
    } else {
    targetLength == UIntSize(15) -> if {
        runInterfaceCache
    } else {
    targetLength == UIntSize(11) -> if {
        pathStart -> emitFingerprints
    } else {
    targetLength == UIntSize(13) -> if {
        pathStart -> buildWindows
    } else {
    targetLength == UIntSize(12) -> if {
        pathStart -> emitWindowsRoot
    } else {
    targetLength == UIntSize(10) -> if {
        pathStart -> emitLinuxRoot
    } else {
    targetLength == UIntSize(9) -> if {
        pathStart -> emitWasmRoot
    } else {
    targetLength == UIntSize(5) -> if {
        pathStart -> emitLinuxFiles
    } else {
        targetLength == UIntSize(4) -> if {
            pathStart -> emitWasmFiles
        } else {
            pathStart -> emitWindowsFiles
        }
    }
    }
    }
    }
    }
    }
    }
    }
    }
}
