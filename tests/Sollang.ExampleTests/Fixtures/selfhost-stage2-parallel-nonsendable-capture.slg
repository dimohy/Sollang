# Verifies that Stage2 follows a local helper to reject its immutable Arena
# capture with E19 before LLVM emission.

inspect seed: Int -> [Int; ~] {
    addUsage value: Int -> Int {
        value + Int(memory -> used)
    }

    Arena(8) => memory
    [1, 2, 3, ~] => values!
    values! -> parallel value {
        value -> addUsage
    } => shifted!
    shifted!
}

main {
    0 -> inspect => shifted!
}
