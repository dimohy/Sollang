# A live readonly reference blocks mutation of its mutable owner.
struct Pair {
    first: Int
}

first pair: ref Pair -> ref Int {
    pair.first
}

read value: ref Int -> Int {
    value
}

main {
    Pair { first: 41 } => pair!
    pair! -> first => borrowed
    42 => pair!.first
    borrowed -> read => observed
    "$(observed)" -> println
}
