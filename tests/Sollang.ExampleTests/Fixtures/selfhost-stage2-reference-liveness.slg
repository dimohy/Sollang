# A branch-selected projected ref locks every overlapping owner place.
struct Inner {
    first: Int
}

struct Outer {
    left: Inner
    right: Inner
    tail: Int
}

choose condition: Bool, left: ref Int, right: ref Int -> ref Int {
    condition -> if {
        left -> return
    }
    right
}

read value: ref Int -> Int {
    value
}

main {
    Outer {
        left: Inner { first: 41 }
        right: Inner { first: 51 }
        tail: 61
    } => outer!
    choose(true, outer!.left.first, outer!.right.first) => borrowed
    Inner { first: 42 } => outer!.left
    borrowed -> read => observed
    "$(observed)" -> println
}
