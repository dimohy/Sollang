# A consuming whole-owner move cannot invalidate a live element reference.
same value: ref Int -> ref Int {
    value
}

read value: ref Int -> Int {
    value
}

consume values: move [Int; ~] -> UIntSize {
    values -> len
}

main {
    [10, 20, ~] => values!
    values![0] -> same => borrowed
    values! -> consume => count
    borrowed -> read => observed
    "observed=$observed,count=$count" -> println
}
