{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "SmallLang",
  "scopeName": "source.smalllang",
  "fileTypes": [
    "sl"
  ],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#function-declarations" },
    { "include": "#namespace-imports" },
    { "include": "#block-function-declarations" },
    { "include": "#each-statements" },
    { "include": "#block-flow-calls" },
    { "include": "#when-arms" },
    { "include": "#yield-calls" },
    { "include": "#bindings" },
    { "include": "#legacy-bindings" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#constants" },
    { "include": "#numbers" },
    { "include": "#function-calls" },
    { "include": "#operators" },
    { "include": "#punctuation" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.smalllang",
          "match": "(#).*$",
          "captures": {
            "1": { "name": "punctuation.definition.comment.smalllang" }
          }
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.smalllang",
          "begin": "\"",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.string.begin.smalllang" }
          },
          "end": "\"",
          "endCaptures": {
            "0": { "name": "punctuation.definition.string.end.smalllang" }
          },
          "patterns": [
            {
              "name": "constant.character.escape.smalllang",
              "match": "\\\\[\\\\\"nrt]"
            },
            {
              "name": "meta.interpolation.expression.smalllang",
              "begin": "\\$\\(",
              "beginCaptures": {
                "0": { "name": "punctuation.section.interpolation.begin.smalllang keyword.operator.interpolation.smalllang" }
              },
              "end": "\\)",
              "endCaptures": {
                "0": { "name": "punctuation.section.interpolation.end.smalllang" }
              },
              "patterns": [
                { "include": "#strings" },
                { "include": "#each-statements" },
                { "include": "#block-flow-calls" },
                { "include": "#when-arms" },
                { "include": "#yield-calls" },
                { "include": "#bindings" },
                { "include": "#legacy-bindings" },
                { "include": "#keywords" },
                { "include": "#types" },
                { "include": "#constants" },
                { "include": "#numbers" },
                { "include": "#function-calls" },
                { "include": "#operators" },
                { "include": "#punctuation" },
                { "include": "#identifiers" }
              ]
            },
            {
              "name": "meta.interpolation.identifier.smalllang",
              "match": "(\\$)([A-Za-z_][A-Za-z0-9_]*)",
              "captures": {
                "1": { "name": "punctuation.section.interpolation.begin.smalllang keyword.operator.interpolation.smalllang" },
                "2": { "name": "variable.other.readwrite.interpolation.smalllang" }
              }
            }
          ]
        }
      ]
    },
    "function-declarations": {
      "patterns": [
        {
          "name": "meta.function.declaration.smalllang",
          "match": "^\\s*([A-Za-z_][A-Za-z0-9_]*(?:\\.[A-Za-z_][A-Za-z0-9_]*)*)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*(:)",
          "captures": {
            "1": { "name": "entity.name.function.smalllang" },
            "2": { "name": "variable.parameter.function.smalllang" },
            "3": { "name": "punctuation.separator.type.smalllang" }
          }
        },
        {
          "name": "meta.function.declaration.smalllang",
          "match": "^\\s*([A-Za-z_][A-Za-z0-9_]*(?:\\.[A-Za-z_][A-Za-z0-9_]*)*)\\s*(:)",
          "captures": {
            "1": { "name": "entity.name.function.smalllang" },
            "2": { "name": "punctuation.separator.type.smalllang" }
          }
        }
      ]
    },
    "namespace-imports": {
      "patterns": [
        {
          "name": "meta.namespace.smalllang",
          "match": "^\\s*(namespace)\\s+([A-Za-z_][A-Za-z0-9_]*(?:\\.[A-Za-z_][A-Za-z0-9_]*)*)",
          "captures": {
            "1": { "name": "keyword.control.import.smalllang" },
            "2": { "name": "entity.name.namespace.smalllang" }
          }
        },
        {
          "name": "meta.import.smalllang",
          "match": "^\\s*(import)\\s+([A-Za-z_][A-Za-z0-9_]*(?:\\.[A-Za-z_][A-Za-z0-9_]*)*)(?:\\s+(as)\\s+([A-Za-z_][A-Za-z0-9_]*))?",
          "captures": {
            "1": { "name": "keyword.control.import.smalllang" },
            "2": { "name": "entity.name.namespace.smalllang" },
            "3": { "name": "keyword.control.import.smalllang" },
            "4": { "name": "entity.name.namespace.alias.smalllang" }
          }
        }
      ]
    },
    "block-function-declarations": {
      "patterns": [
        {
          "name": "meta.block-function.declaration.smalllang",
          "match": "\\b(block)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*(:)",
          "captures": {
            "1": { "name": "keyword.control.smalllang" },
            "2": { "name": "variable.parameter.block.smalllang" },
            "3": { "name": "punctuation.separator.type.smalllang" }
          }
        }
      ]
    },
    "each-statements": {
      "patterns": [
        {
          "name": "meta.loop.each.in.smalllang",
          "match": "\\b(each)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s+(in)\\b",
          "captures": {
            "1": { "name": "keyword.control.loop.each.smalllang" },
            "2": { "name": "variable.parameter.loop.smalllang" },
            "3": { "name": "keyword.control.loop.in.smalllang" }
          }
        }
      ]
    },
    "block-flow-calls": {
      "patterns": [
        {
          "name": "meta.block-function-call.fold.smalllang",
          "match": "(->)\\s*(fold)\\s+([^\\s{}]+)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*(,)\\s*([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\{)",
          "captures": {
            "1": { "name": "keyword.operator.flow.smalllang" },
            "2": { "name": "keyword.control.loop.fold.smalllang" },
            "3": { "name": "meta.fold.seed.smalllang" },
            "4": { "name": "variable.parameter.fold.accumulator.smalllang" },
            "5": { "name": "punctuation.separator.comma.smalllang" },
            "6": { "name": "variable.parameter.fold.item.smalllang" }
          }
        },
        {
          "name": "meta.block-function-call.conditional.smalllang",
          "match": "(->)\\s*(if|when)\\b\\s*(?=\\{)",
          "captures": {
            "1": { "name": "keyword.operator.flow.smalllang" },
            "2": { "name": "keyword.control.conditional.smalllang" }
          }
        },
        {
          "name": "meta.block-function-call.smalllang",
          "match": "(->)\\s*(each|repeat)\\b(?:\\s+([A-Za-z_][A-Za-z0-9_]*))?\\s*(?=\\{)",
          "captures": {
            "1": { "name": "keyword.operator.flow.smalllang" },
            "2": { "name": "keyword.control.loop.smalllang" },
            "3": { "name": "variable.parameter.block.smalllang" }
          }
        }
      ]
    },
    "when-arms": {
      "patterns": [
        {
          "name": "keyword.control.conditional.else.smalllang",
          "match": "^\\s*(else)\\b(?=\\s*(?:->|=>|\\{))",
          "captures": {
            "1": { "name": "keyword.control.conditional.else.smalllang" }
          }
        },
        {
          "name": "meta.when-arm.comparison.smalllang",
          "match": "^\\s*(==|!=|<=|>=|<|>)\\s*(?=\\S)",
          "captures": {
            "1": { "name": "keyword.operator.comparison.smalllang" }
          }
        },
        {
          "name": "meta.when-arm.range.smalllang",
          "match": "^\\s*(\\d+)\\s*(\\.\\.)\\s*(\\d+)\\s*(?=\\{|=>|->)",
          "captures": {
            "1": { "name": "constant.numeric.integer.decimal.smalllang" },
            "2": { "name": "keyword.operator.range.smalllang" },
            "3": { "name": "constant.numeric.integer.decimal.smalllang" }
          }
        }
      ]
    },
    "yield-calls": {
      "patterns": [
        {
          "name": "meta.yield-call.smalllang",
          "match": "\\b(yield)\\s*(\\(\\))",
          "captures": {
            "1": { "name": "keyword.control.flow.yield.smalllang" },
            "2": { "name": "punctuation.definition.call.empty.smalllang" }
          }
        }
      ]
    },
    "bindings": {
      "patterns": [
        {
          "name": "meta.binding.smalllang",
          "match": "(=>)\\s*([A-Za-z_][A-Za-z0-9_]*)(!)?(?=\\s*(?:#.*)?$|\\s*[})\\]])",
          "captures": {
            "1": { "name": "keyword.operator.binding.smalllang" },
            "2": { "name": "variable.other.readwrite.binding.smalllang" },
            "3": { "name": "storage.modifier.mutable.smalllang punctuation.definition.mutable-owner.smalllang" }
          }
        }
      ]
    },
    "legacy-bindings": {
      "patterns": [
        {
          "name": "meta.binding.legacy-assignment.smalllang",
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s*(=)(?![=>])",
          "captures": {
            "1": { "name": "variable.other.readwrite.binding.smalllang" },
            "2": { "name": "keyword.operator.assignment.smalllang" }
          }
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.import.smalllang",
          "match": "\\b(namespace|import|as|move|mut)\\b"
        },
        {
          "name": "keyword.control.conditional.smalllang",
          "match": "\\b(else|when|if)\\b"
        },
        {
          "name": "keyword.control.loop.smalllang",
          "match": "\\b(each|in|repeat|fold)\\b"
        },
        {
          "name": "keyword.control.flow.yield.smalllang",
          "match": "\\byield\\b"
        },
        {
          "name": "keyword.control.main.smalllang",
          "match": "\\bmain\\b"
        },
        {
          "name": "keyword.control.declaration.block.smalllang",
          "match": "\\bblock\\b"
        },
        {
          "name": "keyword.other.intrinsic.smalllang",
          "match": "\\bintrinsic\\b"
        },
        {
          "name": "keyword.operator.logical.smalllang",
          "match": "\\b(and|or|not)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.builtin.smalllang",
          "match": "\\b(Unit|Text|Int|Bool|Io)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.smalllang",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "variable.language.special.smalllang",
          "match": "\\bit\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.integer.decimal.smalllang",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "function-calls": {
      "patterns": [
        {
          "name": "meta.function-call.flow.smalllang",
          "match": "(->)\\s*((?!(?:if|when|fold|each|repeat|Unit|Text|Int|Bool|Io|and|or|not|else|main|block|yield|namespace|import|as|move|mut|intrinsic|in)\\b)[A-Za-z_][A-Za-z0-9_]*(?:\\.[A-Za-z_][A-Za-z0-9_]*)*)\\b",
          "captures": {
            "1": { "name": "keyword.operator.flow.smalllang" },
            "2": { "name": "entity.name.function.call.smalllang" }
          }
        },
        {
          "name": "meta.function-call.smalllang",
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*(?:\\.[A-Za-z_][A-Za-z0-9_]*)*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.function.call.smalllang" }
          }
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.flow.smalllang",
          "match": "->"
        },
        {
          "name": "keyword.operator.binding.smalllang",
          "match": "=>"
        },
        {
          "name": "keyword.operator.range.smalllang",
          "match": "\\.\\."
        },
        {
          "name": "keyword.operator.growable.smalllang",
          "match": "~"
        },
        {
          "name": "keyword.operator.comparison.smalllang",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.assignment.smalllang",
          "match": "(?<![=!<>])=(?![=>])"
        },
        {
          "name": "keyword.operator.arithmetic.smalllang",
          "match": "[+\\-*/%]"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.definition.dictionary.begin.smalllang",
          "match": "\\{(?=\\s*[^}\\n]+\\s*:)"
        },
        {
          "name": "punctuation.separator.dictionary.key-value.smalllang",
          "match": ":"
        },
        {
          "name": "punctuation.section.block.smalllang",
          "match": "[{}]"
        },
        {
          "name": "punctuation.section.group.begin.smalllang",
          "match": "\\("
        },
        {
          "name": "punctuation.section.group.end.smalllang",
          "match": "\\)"
        },
        {
          "name": "punctuation.definition.sequence.begin.smalllang",
          "match": "\\["
        },
        {
          "name": "punctuation.definition.sequence.end.smalllang",
          "match": "\\]"
        },
        {
          "name": "punctuation.separator.comma.smalllang",
          "match": ","
        },
        {
          "name": "punctuation.terminator.statement.smalllang",
          "match": ";"
        },
        {
          "name": "punctuation.accessor.dot.smalllang",
          "match": "\\."
        },
        {
          "name": "punctuation.separator.type.smalllang",
          "match": ":"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.readwrite.smalllang",
          "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b"
        }
      ]
    }
  }
}
