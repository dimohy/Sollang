{
  "name": "smalllang-syntax",
  "displayName": "SmallLang Syntax",
  "description": "Syntax highlighting and editor support for SmallLang .sl files.",
  "version": "0.1.0",
  "publisher": "dimohy",
  "license": "Apache-2.0",
  "engines": {
    "vscode": "^1.92.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "scripts": {
    "package": "vsce package --no-dependencies --allow-missing-repository"
  },
  "contributes": {
    "languages": [
      {
        "id": "smalllang",
        "aliases": [
          "SmallLang",
          "smalllang"
        ],
        "extensions": [
          ".sl"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "smalllang",
        "scopeName": "source.smalllang",
        "path": "./syntaxes/smalllang.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "smalllang",
        "path": "./snippets/smalllang.code-snippets"
      }
    ]
  }
}
