{
  "name": "smalllang-language-support",
  "displayName": "SmallLang Language Support",
  "description": "Language support for SmallLang .sl files.",
  "version": "0.2.0",
  "publisher": "dimohy",
  "license": "Apache-2.0",
  "icon": "images/smalllang-logo.png",
  "engines": {
    "vscode": "^1.92.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "scripts": {
    "package": "vsce package --no-dependencies --allow-missing-repository"
  },
  "contributes": {
    "languages": [
      {
        "id": "smalllang",
        "aliases": [
          "SmallLang",
          "smalllang"
        ],
        "extensions": [
          ".sl"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "smalllang",
        "scopeName": "source.smalllang",
        "path": "./syntaxes/smalllang.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "smalllang",
        "path": "./snippets/smalllang.code-snippets"
      }
    ],
    "configurationDefaults": {
      "editor.tokenColorCustomizations": {
        "textMateRules": [
          {
            "scope": [
              "source.smalllang string.quoted.double.smalllang",
              "source.smalllang punctuation.definition.string.begin.smalllang",
              "source.smalllang punctuation.definition.string.end.smalllang"
            ],
            "settings": {
              "foreground": "#CE9178"
            }
          },
          {
            "scope": [
              "source.smalllang comment.line.number-sign.smalllang",
              "source.smalllang punctuation.definition.comment.smalllang"
            ],
            "settings": {
              "foreground": "#6A9955"
            }
          },
          {
            "scope": [
              "source.smalllang keyword.control.smalllang",
              "source.smalllang keyword.control.import.smalllang",
              "source.smalllang keyword.control.conditional.smalllang",
              "source.smalllang keyword.control.loop.smalllang",
              "source.smalllang keyword.control.loop.each.smalllang",
              "source.smalllang keyword.control.loop.in.smalllang",
              "source.smalllang keyword.control.loop.fold.smalllang",
              "source.smalllang keyword.control.flow.yield.smalllang",
              "source.smalllang keyword.control.main.smalllang",
              "source.smalllang keyword.control.declaration.block.smalllang",
              "source.smalllang keyword.other.intrinsic.smalllang",
              "source.smalllang storage.modifier.mutable.smalllang",
              "source.smalllang keyword.operator.flow.smalllang",
              "source.smalllang keyword.operator.binding.smalllang",
              "source.smalllang keyword.operator.logical.smalllang"
            ],
            "settings": {
              "foreground": "#C586C0"
            }
          },
          {
            "scope": [
              "source.smalllang storage.type.smalllang",
              "source.smalllang storage.type.builtin.smalllang",
              "source.smalllang entity.name.namespace.smalllang",
              "source.smalllang entity.name.namespace.alias.smalllang"
            ],
            "settings": {
              "foreground": "#4EC9B0"
            }
          },
          {
            "scope": [
              "source.smalllang variable.other.readwrite.smalllang",
              "source.smalllang variable.other.readwrite.binding.smalllang",
              "source.smalllang variable.other.readwrite.interpolation.smalllang",
              "source.smalllang string.quoted.double.smalllang variable.other.readwrite.interpolation.smalllang",
              "source.smalllang punctuation.section.interpolation.begin.smalllang",
              "source.smalllang string.quoted.double.smalllang punctuation.section.interpolation.begin.smalllang",
              "source.smalllang variable.parameter.function.smalllang",
              "source.smalllang variable.parameter.block.smalllang",
              "source.smalllang variable.parameter.loop.smalllang",
              "source.smalllang variable.parameter.fold.accumulator.smalllang",
              "source.smalllang variable.parameter.fold.item.smalllang",
              "source.smalllang variable.language.special.smalllang"
            ],
            "settings": {
              "foreground": "#4FC1FF"
            }
          },
          {
            "scope": [
              "source.smalllang keyword.operator.range.smalllang",
              "source.smalllang keyword.operator.arithmetic.smalllang",
              "source.smalllang keyword.operator.comparison.smalllang",
              "source.smalllang keyword.operator.assignment.smalllang"
            ],
            "settings": {
              "foreground": "#D19A66"
            }
          },
          {
            "scope": "source.smalllang constant.numeric.integer.decimal.smalllang",
            "settings": {
              "foreground": "#B5CEA8"
            }
          },
          {
            "scope": "source.smalllang constant.language.boolean.smalllang",
            "settings": {
              "foreground": "#569CD6"
            }
          },
          {
            "scope": [
              "source.smalllang punctuation.section.block.smalllang",
              "source.smalllang punctuation.section.group.begin.smalllang",
              "source.smalllang punctuation.section.group.end.smalllang",
              "source.smalllang punctuation.definition.sequence.begin.smalllang",
              "source.smalllang punctuation.definition.sequence.end.smalllang",
              "source.smalllang punctuation.definition.dictionary.begin.smalllang",
              "source.smalllang punctuation.separator.dictionary.key-value.smalllang",
              "source.smalllang punctuation.separator.type.smalllang",
              "source.smalllang punctuation.separator.comma.smalllang",
              "source.smalllang punctuation.terminator.statement.smalllang",
              "source.smalllang punctuation.accessor.dot.smalllang",
              "source.smalllang punctuation.definition.call.empty.smalllang"
            ],
            "settings": {
              "foreground": "#808080"
            }
          }
        ]
      }
    }
  }
}
