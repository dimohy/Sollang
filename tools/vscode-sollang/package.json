{
  "name": "sollang-language-support",
  "displayName": "Sollang Language Support",
  "description": "Language support for Sollang source, project, and workspace files.",
  "version": "0.6.0",
  "publisher": "dimohy",
  "license": "Apache-2.0",
  "icon": "images/sollang-logo.png",
  "engines": {
    "vscode": "^1.92.0"
  },
  "main": "./extension.js",
  "activationEvents": [
    "onLanguage:sollang"
  ],
  "categories": [
    "Programming Languages"
  ],
  "scripts": {
    "package": "vsce package --no-dependencies --allow-missing-repository"
  },
  "contributes": {
    "configuration": {
      "title": "Sollang",
      "properties": {
        "sollang.compilerPath": {
          "type": "string",
          "default": "sollang",
          "description": "Path to the Sollang compiler used for parser-backed formatting."
        }
      }
    },
    "languages": [
      {
        "id": "sollang",
        "aliases": [
          "Sollang",
          "sollang"
        ],
        "extensions": [
          ".slg"
        ],
        "filenames": [
          "sollang.project",
          "sollang.workspace"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "sollang",
        "scopeName": "source.sollang",
        "path": "./syntaxes/sollang.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "sollang",
        "path": "./snippets/sollang.code-snippets"
      }
    ],
    "configurationDefaults": {
      "editor.tokenColorCustomizations": {
        "textMateRules": [
          {
            "scope": [
              "source.sollang string.quoted.double.sollang",
              "source.sollang string.quoted.triple.sollang",
              "source.sollang punctuation.definition.string.begin.sollang",
              "source.sollang punctuation.definition.string.end.sollang"
            ],
            "settings": {
              "foreground": "#CE9178"
            }
          },
          {
            "scope": [
              "source.sollang comment.line.number-sign.sollang",
              "source.sollang punctuation.definition.comment.sollang"
            ],
            "settings": {
              "foreground": "#6A9955"
            }
          },
          {
            "scope": [
              "source.sollang keyword.control.sollang",
              "source.sollang keyword.control.import.sollang",
              "source.sollang keyword.control.conditional.sollang",
              "source.sollang keyword.control.loop.sollang",
              "source.sollang keyword.control.loop.each.sollang",
              "source.sollang keyword.control.loop.in.sollang",
              "source.sollang keyword.control.loop.fold.sollang",
              "source.sollang keyword.control.async.sollang",
              "source.sollang keyword.control.flow.yield.sollang",
              "source.sollang keyword.control.main.sollang",
              "source.sollang keyword.control.declaration.block.sollang",
              "source.sollang keyword.other.intrinsic.sollang",
              "source.sollang keyword.other.memory.sollang",
              "source.sollang storage.modifier.sollang",
              "source.sollang storage.modifier.visibility.sollang",
              "source.sollang storage.modifier.mutable.sollang",
              "source.sollang keyword.operator.flow.sollang",
              "source.sollang keyword.operator.binding.sollang",
              "source.sollang keyword.operator.logical.sollang"
            ],
            "settings": {
              "foreground": "#C586C0"
            }
          },
          {
            "scope": [
              "source.sollang storage.type.sollang",
              "source.sollang storage.type.builtin.sollang",
              "source.sollang storage.type.declaration.sollang",
              "source.sollang storage.type.implementation.sollang",
              "source.sollang entity.name.type.sollang",
              "source.sollang entity.name.type.nominal.sollang",
              "source.sollang entity.name.namespace.sollang",
              "source.sollang entity.name.namespace.alias.sollang"
            ],
            "settings": {
              "foreground": "#4EC9B0"
            }
          },
          {
            "scope": [
              "source.sollang variable.other.readwrite.sollang",
              "source.sollang variable.other.readwrite.binding.sollang",
              "source.sollang variable.other.readwrite.interpolation.sollang",
              "source.sollang string.quoted.double.sollang variable.other.readwrite.interpolation.sollang",
              "source.sollang punctuation.section.interpolation.begin.sollang",
              "source.sollang string.quoted.double.sollang punctuation.section.interpolation.begin.sollang",
              "source.sollang variable.parameter.function.sollang",
              "source.sollang variable.parameter.block.sollang",
              "source.sollang variable.parameter.loop.sollang",
              "source.sollang variable.parameter.fold.accumulator.sollang",
              "source.sollang variable.parameter.fold.item.sollang",
              "source.sollang variable.language.special.sollang"
            ],
            "settings": {
              "foreground": "#4FC1FF"
            }
          },
          {
            "scope": [
              "source.sollang keyword.operator.range.sollang",
              "source.sollang keyword.operator.arithmetic.sollang",
              "source.sollang keyword.operator.comparison.sollang",
              "source.sollang keyword.operator.assignment.sollang",
              "source.sollang keyword.operator.propagation.sollang"
            ],
            "settings": {
              "foreground": "#D19A66"
            }
          },
          {
            "scope": [
              "source.sollang constant.numeric.integer.decimal.sollang",
              "source.sollang constant.numeric.float.sollang"
            ],
            "settings": {
              "foreground": "#B5CEA8"
            }
          },
          {
            "scope": "source.sollang constant.language.boolean.sollang",
            "settings": {
              "foreground": "#569CD6"
            }
          },
          {
            "scope": [
              "source.sollang punctuation.section.block.sollang",
              "source.sollang punctuation.section.group.begin.sollang",
              "source.sollang punctuation.section.group.end.sollang",
              "source.sollang punctuation.definition.sequence.begin.sollang",
              "source.sollang punctuation.definition.sequence.end.sollang",
              "source.sollang punctuation.definition.dictionary.begin.sollang",
              "source.sollang punctuation.separator.dictionary.key-value.sollang",
              "source.sollang punctuation.separator.type.sollang",
              "source.sollang punctuation.separator.comma.sollang",
              "source.sollang punctuation.terminator.statement.sollang",
              "source.sollang punctuation.accessor.dot.sollang",
              "source.sollang punctuation.definition.call.empty.sollang",
              "source.sollang punctuation.definition.type-arguments.begin.sollang",
              "source.sollang punctuation.definition.type-arguments.end.sollang"
            ],
            "settings": {
              "foreground": "#808080"
            }
          }
        ]
      }
    }
  }
}
