{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Sollang",
  "scopeName": "source.sollang",
  "fileTypes": [
    "slg"
  ],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#type-declarations" },
    { "include": "#function-declarations" },
    { "include": "#namespace-imports" },
    { "include": "#block-function-declarations" },
    { "include": "#each-statements" },
    { "include": "#async-flow-targets" },
    { "include": "#block-flow-calls" },
    { "include": "#when-arms" },
    { "include": "#yield-calls" },
    { "include": "#bindings" },
    { "include": "#legacy-bindings" },
    { "include": "#keywords" },
    { "include": "#generic-clauses" },
    { "include": "#types" },
    { "include": "#nominal-types" },
    { "include": "#constants" },
    { "include": "#numbers" },
    { "include": "#function-calls" },
    { "include": "#operators" },
    { "include": "#punctuation" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.sollang",
          "match": "(#).*$",
          "captures": {
            "1": { "name": "punctuation.definition.comment.sollang" }
          }
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.triple.sollang",
          "begin": "(\"{3,})",
          "beginCaptures": {
            "1": { "name": "punctuation.definition.string.begin.sollang" }
          },
          "end": "(\\1)",
          "endCaptures": {
            "1": { "name": "punctuation.definition.string.end.sollang" }
          }
        },
        {
          "name": "string.quoted.double.sollang",
          "begin": "\"",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.string.begin.sollang" }
          },
          "end": "\"",
          "endCaptures": {
            "0": { "name": "punctuation.definition.string.end.sollang" }
          },
          "patterns": [
            {
              "name": "constant.character.escape.sollang",
              "match": "\\\\[\\\\\"nrt]"
            },
            {
              "name": "meta.interpolation.expression.sollang",
              "begin": "\\$\\(",
              "beginCaptures": {
                "0": { "name": "punctuation.section.interpolation.begin.sollang keyword.operator.interpolation.sollang" }
              },
              "end": "\\)",
              "endCaptures": {
                "0": { "name": "punctuation.section.interpolation.end.sollang" }
              },
              "patterns": [
                { "include": "#strings" },
                { "include": "#each-statements" },
                { "include": "#block-flow-calls" },
                { "include": "#when-arms" },
                { "include": "#yield-calls" },
                { "include": "#bindings" },
                { "include": "#legacy-bindings" },
                { "include": "#keywords" },
                { "include": "#types" },
                { "include": "#constants" },
                { "include": "#numbers" },
                { "include": "#function-calls" },
                { "include": "#operators" },
                { "include": "#punctuation" },
                { "include": "#identifiers" }
              ]
            },
            {
              "name": "meta.interpolation.identifier.sollang",
              "match": "(\\$)([A-Za-z_][A-Za-z0-9_]*)",
              "captures": {
                "1": { "name": "punctuation.section.interpolation.begin.sollang keyword.operator.interpolation.sollang" },
                "2": { "name": "variable.other.readwrite.interpolation.sollang" }
              }
            }
          ]
        }
      ]
    },
    "type-declarations": {
      "patterns": [
        {
          "name": "meta.type.declaration.sollang",
          "match": "^\\s*(?:(public)\\s+)?(struct|enum|effect|trait)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "storage.modifier.visibility.sollang" },
            "2": { "name": "storage.type.declaration.sollang" },
            "3": { "name": "entity.name.type.sollang" }
          }
        },
        {
          "name": "meta.type.implementation.sollang",
          "match": "^\\s*(impl)\\s+([A-Za-z_][A-Za-z0-9_.]*)(?:\\s+(for)\\s+([A-Za-z_][A-Za-z0-9_.]*))?",
          "captures": {
            "1": { "name": "storage.type.implementation.sollang" },
            "2": { "name": "entity.name.type.sollang" },
            "3": { "name": "storage.type.implementation.sollang" },
            "4": { "name": "entity.name.type.sollang" }
          }
        },
        {
          "name": "meta.associated-type.declaration.sollang",
          "match": "^\\s*(type)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "storage.type.declaration.sollang" },
            "2": { "name": "entity.name.type.sollang" }
          }
        }
      ]
    },
    "function-declarations": {
      "patterns": [
        {
          "name": "meta.function.declaration.sollang",
          "match": "^\\s*(?:public\\s+)?([A-Za-z_][A-Za-z0-9_]*(?:\\.[A-Za-z_][A-Za-z0-9_]*)*)(?:\\s*<[^>\\n]+>)?(?:\\s+where\\s+[^\\n]+?)?\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*(:)(?=[^\\n{}]*(?:->|=>|=\\s*intrinsic))",
          "captures": {
            "1": { "name": "entity.name.function.sollang" },
            "2": { "name": "variable.parameter.function.sollang" },
            "3": { "name": "punctuation.separator.type.sollang" }
          }
        },
        {
          "name": "meta.function.declaration.sollang",
          "match": "^\\s*(?:public\\s+)?([A-Za-z_][A-Za-z0-9_]*(?:\\.[A-Za-z_][A-Za-z0-9_]*)*)(?:\\s*<[^>\\n]+>)?(?:\\s+where\\s+[^\\n]+?)?\\s*(:)(?=[^\\n{}]*(?:->|=>|=\\s*intrinsic))",
          "captures": {
            "1": { "name": "entity.name.function.sollang" },
            "2": { "name": "punctuation.separator.type.sollang" }
          }
        }
      ]
    },
    "namespace-imports": {
      "patterns": [
        {
          "name": "meta.namespace.sollang",
          "match": "^\\s*(namespace)\\s+([A-Za-z_][A-Za-z0-9_]*(?:\\.[A-Za-z_][A-Za-z0-9_]*)*)",
          "captures": {
            "1": { "name": "keyword.control.import.sollang" },
            "2": { "name": "entity.name.namespace.sollang" }
          }
        },
        {
          "name": "meta.import.sollang",
          "match": "^\\s*(import)\\s+([A-Za-z_][A-Za-z0-9_]*(?:\\.[A-Za-z_][A-Za-z0-9_]*)*)(?:\\s+(as)\\s+([A-Za-z_][A-Za-z0-9_]*))?",
          "captures": {
            "1": { "name": "keyword.control.import.sollang" },
            "2": { "name": "entity.name.namespace.sollang" },
            "3": { "name": "keyword.control.import.sollang" },
            "4": { "name": "entity.name.namespace.alias.sollang" }
          }
        }
      ]
    },
    "block-function-declarations": {
      "patterns": [
        {
          "name": "meta.block-function.declaration.sollang",
          "match": "\\b(block)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*(:)",
          "captures": {
            "1": { "name": "keyword.control.sollang" },
            "2": { "name": "variable.parameter.block.sollang" },
            "3": { "name": "punctuation.separator.type.sollang" }
          }
        }
      ]
    },
    "each-statements": {
      "patterns": [
        {
          "name": "meta.loop.each.in.sollang",
          "match": "\\b(each)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s+(in)\\b",
          "captures": {
            "1": { "name": "keyword.control.loop.each.sollang" },
            "2": { "name": "variable.parameter.loop.sollang" },
            "3": { "name": "keyword.control.loop.in.sollang" }
          }
        }
      ]
    },
    "block-flow-calls": {
      "patterns": [
        {
          "name": "meta.block-function-call.fold.sollang",
          "match": "(->)\\s*(fold)\\s+([^\\s{}]+)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*(,)\\s*([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\{)",
          "captures": {
            "1": { "name": "keyword.operator.flow.sollang" },
            "2": { "name": "keyword.control.loop.fold.sollang" },
            "3": { "name": "meta.fold.seed.sollang" },
            "4": { "name": "variable.parameter.fold.accumulator.sollang" },
            "5": { "name": "punctuation.separator.comma.sollang" },
            "6": { "name": "variable.parameter.fold.item.sollang" }
          }
        },
        {
          "name": "meta.block-function-call.conditional.sollang",
          "match": "(->)\\s*(if|when)\\b\\s*(?=\\{)",
          "captures": {
            "1": { "name": "keyword.operator.flow.sollang" },
            "2": { "name": "keyword.control.conditional.sollang" }
          }
        },
        {
          "name": "meta.block-function-call.sollang",
          "match": "(->)\\s*(each|repeat)\\b(?:\\s+([A-Za-z_][A-Za-z0-9_]*))?\\s*(?=\\{)",
          "captures": {
            "1": { "name": "keyword.operator.flow.sollang" },
            "2": { "name": "keyword.control.loop.sollang" },
            "3": { "name": "variable.parameter.block.sollang" }
          }
        }
      ]
    },
    "async-flow-targets": {
      "patterns": [
        {
          "name": "meta.async-flow-target.sollang",
          "match": "(->)\\s*(await|cancel)\\b",
          "captures": {
            "1": { "name": "keyword.operator.flow.sollang" },
            "2": { "name": "keyword.control.async.sollang" }
          }
        }
      ]
    },
    "when-arms": {
      "patterns": [
        {
          "name": "keyword.control.conditional.else.sollang",
          "match": "^\\s*(else)\\b(?=\\s*(?:->|=>|\\{))",
          "captures": {
            "1": { "name": "keyword.control.conditional.else.sollang" }
          }
        },
        {
          "name": "meta.when-arm.comparison.sollang",
          "match": "^\\s*(==|!=|<=|>=|<|>)\\s*(?=\\S)",
          "captures": {
            "1": { "name": "keyword.operator.comparison.sollang" }
          }
        },
        {
          "name": "meta.when-arm.range.sollang",
          "match": "^\\s*(\\d+)\\s*(\\.\\.)\\s*(\\d+)\\s*(?=\\{|=>|->)",
          "captures": {
            "1": { "name": "constant.numeric.integer.decimal.sollang" },
            "2": { "name": "keyword.operator.range.sollang" },
            "3": { "name": "constant.numeric.integer.decimal.sollang" }
          }
        }
      ]
    },
    "yield-calls": {
      "patterns": [
        {
          "name": "meta.yield-call.sollang",
          "match": "\\b(yield)\\s*(\\(\\))",
          "captures": {
            "1": { "name": "keyword.control.flow.yield.sollang" },
            "2": { "name": "punctuation.definition.call.empty.sollang" }
          }
        }
      ]
    },
    "bindings": {
      "patterns": [
        {
          "name": "meta.binding.sollang",
          "match": "(=>)\\s*([A-Za-z_][A-Za-z0-9_]*)(!)?(?=\\s*(?:#.*)?$|\\s*[})\\]])",
          "captures": {
            "1": { "name": "keyword.operator.binding.sollang" },
            "2": { "name": "variable.other.readwrite.binding.sollang" },
            "3": { "name": "storage.modifier.mutable.sollang punctuation.definition.mutable-owner.sollang" }
          }
        }
      ]
    },
    "legacy-bindings": {
      "patterns": [
        {
          "name": "meta.binding.legacy-assignment.sollang",
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s*(=)(?![=>])",
          "captures": {
            "1": { "name": "variable.other.readwrite.binding.sollang" },
            "2": { "name": "keyword.operator.assignment.sollang" }
          }
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.import.sollang",
          "match": "\\b(namespace|import|as)\\b"
        },
        {
          "name": "keyword.control.declaration.manifest.sollang",
          "match": "\\b(project|workspace|name|root|products|dependencies|members)\\b"
        },
        {
          "name": "storage.modifier.sollang",
          "match": "\\b(public|move|mut|async)\\b"
        },
        {
          "name": "keyword.control.async.sollang",
          "match": "\\b(await|cancel)\\b"
        },
        {
          "name": "storage.type.declaration.sollang",
          "match": "\\b(struct|enum|effect|trait|impl|type|for|where|uses)\\b"
        },
        {
          "name": "keyword.control.conditional.sollang",
          "match": "\\b(else|when|if)\\b"
        },
        {
          "name": "keyword.control.loop.sollang",
          "match": "\\b(each|in|repeat|fold|while|break|continue)\\b"
        },
        {
          "name": "keyword.control.flow.yield.sollang",
          "match": "\\b(yield|return)\\b"
        },
        {
          "name": "keyword.control.main.sollang",
          "match": "\\bmain\\b"
        },
        {
          "name": "keyword.control.declaration.block.sollang",
          "match": "\\bblock\\b"
        },
        {
          "name": "keyword.other.intrinsic.sollang",
          "match": "\\bintrinsic\\b"
        },
        {
          "name": "keyword.operator.logical.sollang",
          "match": "\\b(and|or|not)\\b"
        },
        {
          "name": "keyword.other.memory.sollang",
          "match": "\\b(box|map|read|write|at|size)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.builtin.sollang",
          "match": "\\b(Unit|Text|Bool|Int|Int8|Int16|Int32|Int64|Long|UInt8|UInt16|UInt32|UInt64|Size|UIntSize|CodePoint|Float|Float32|Float64|Double|Arena|Arguments|SourceText|MappedBytes|MutableMappedBytes|Io|Option|Result|Task)\\b"
        }
      ]
    },
    "nominal-types": {
      "patterns": [
        {
          "name": "entity.name.type.nominal.sollang",
          "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
        }
      ]
    },
    "generic-clauses": {
      "patterns": [
        {
          "name": "meta.type-arguments.sollang",
          "begin": "(?<=[A-Za-z0-9_])(<)(?=\\s*(?:[A-Z][A-Za-z0-9_.]*|\\d))",
          "beginCaptures": {
            "1": { "name": "punctuation.definition.type-arguments.begin.sollang" }
          },
          "end": ">",
          "endCaptures": {
            "0": { "name": "punctuation.definition.type-arguments.end.sollang" }
          },
          "patterns": [
            { "include": "#types" },
            { "include": "#nominal-types" },
            { "include": "#numbers" },
            { "include": "#punctuation" },
            { "include": "#identifiers" }
          ]
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.sollang",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "variable.language.special.sollang",
          "match": "\\b(it|self)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.sollang",
          "match": "\\b(?:\\d(?:_?\\d)*)?\\.\\d(?:_?\\d)*(?:[eE][+-]?\\d(?:_?\\d)*)?\\b|\\b\\d(?:_?\\d)*[eE][+-]?\\d(?:_?\\d)*\\b"
        },
        {
          "name": "constant.numeric.integer.decimal.sollang",
          "match": "\\b\\d(?:_?\\d)*\\b"
        }
      ]
    },
    "function-calls": {
      "patterns": [
        {
          "name": "meta.function-call.flow.sollang",
          "match": "(->)\\s*((?!(?:if|when|fold|each|repeat|while|break|continue|return|await|cancel|Unit|Text|Bool|Int|Int8|Int16|Int32|Int64|Long|UInt8|UInt16|UInt32|UInt64|Size|UIntSize|CodePoint|Float|Float32|Float64|Double|Arena|Arguments|SourceText|MappedBytes|MutableMappedBytes|Io|Option|Result|Task|and|or|not|else|main|block|yield|namespace|import|as|public|move|mut|async|uses|struct|enum|effect|trait|impl|type|for|where|box|map|read|write|at|size|intrinsic|in)\\b)[A-Za-z_][A-Za-z0-9_]*(?:\\.[A-Za-z_][A-Za-z0-9_]*)*)\\b",
          "captures": {
            "1": { "name": "keyword.operator.flow.sollang" },
            "2": { "name": "entity.name.function.call.sollang" }
          }
        },
        {
          "name": "meta.function-call.sollang",
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*(?:\\.[A-Za-z_][A-Za-z0-9_]*)*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.function.call.sollang" }
          }
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.flow.sollang",
          "match": "->"
        },
        {
          "name": "keyword.operator.binding.sollang",
          "match": "=>"
        },
        {
          "name": "keyword.operator.range.sollang",
          "match": "\\.\\."
        },
        {
          "name": "keyword.operator.growable.sollang",
          "match": "~"
        },
        {
          "name": "keyword.operator.propagation.sollang",
          "match": "\\?"
        },
        {
          "name": "storage.modifier.mutable.sollang",
          "match": "!(?!=)"
        },
        {
          "name": "keyword.operator.comparison.sollang",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.assignment.sollang",
          "match": "(?<![=!<>])=(?![=>])"
        },
        {
          "name": "keyword.operator.arithmetic.sollang",
          "match": "[+\\-*/%]"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.definition.dictionary.begin.sollang",
          "match": "\\{(?=\\s*[^}\\n]+\\s*:)"
        },
        {
          "name": "punctuation.separator.dictionary.key-value.sollang",
          "match": ":"
        },
        {
          "name": "punctuation.section.block.sollang",
          "match": "[{}]"
        },
        {
          "name": "punctuation.section.group.begin.sollang",
          "match": "\\("
        },
        {
          "name": "punctuation.section.group.end.sollang",
          "match": "\\)"
        },
        {
          "name": "punctuation.definition.sequence.begin.sollang",
          "match": "\\["
        },
        {
          "name": "punctuation.definition.sequence.end.sollang",
          "match": "\\]"
        },
        {
          "name": "punctuation.separator.comma.sollang",
          "match": ","
        },
        {
          "name": "punctuation.terminator.statement.sollang",
          "match": ";"
        },
        {
          "name": "punctuation.accessor.dot.sollang",
          "match": "\\."
        },
        {
          "name": "punctuation.separator.type.sollang",
          "match": ":"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.readwrite.sollang",
          "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b"
        }
      ]
    }
  }
}
