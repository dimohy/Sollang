import std.sequence

observe value: Int -> Int uses Console {
    "observe=$value" -> println
    value
}

main {
    1..2
        -> beforeEach outer { }
        -> flatMap(1..2) outer, inner {
            outer * 10 + inner -> observe => observed
            "line=$observed"
        }
        -> each line {
            line -> println
        }
}
