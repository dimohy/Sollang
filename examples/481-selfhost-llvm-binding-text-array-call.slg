import sollang.compiler.llvm.text as llvm

main {
    [
        """
        count values: [Text; ~] -> Int => Int(values -> len)

        main {
            "lexer" => first
            "parser" => second
            [first, second, ~] -> count => length
            "count=$length" -> println
        }
        """,
        ~
    ] => sources!
    sources! -> llvm.emit
}
