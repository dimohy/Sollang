double value: -> {
    value * 2
}

constant: -> {
    1
}

run seed: Int -> Int {
    increment value: -> {
        value + 1
    }

    offset value: Int -> {
        value + 1
    }

    triple value: -> Int {
        value * 3
    }

    seed -> increment => next
    next -> offset => shifted
    shifted -> triple => tripled
    double(tripled) + constant
}

main {
    20 -> run => result
    "inferred signatures = $result" -> println
}
