import sollang.compiler.lexer as lexer
import sollang.compiler.parser as parser
import sollang.compiler.cst as cst

main {
    """
    main {
        @
    }
    """ => source
    source -> lexer.lex => tokens!
    tokens![5].kind => invalidKind
    source -> parser.parseEvents => events!
    events! -> len => eventCount
    events![eventCount - 1].value => accepted
    source -> cst.build => nodes!
    nodes![0] => root
    "invalid kind = $invalidKind" -> println
    "accepted = $accepted" -> println
    "root tokens = $(root.tokenCount)" -> println
    "root span = $(root.start),$(root.length)" -> println
}
