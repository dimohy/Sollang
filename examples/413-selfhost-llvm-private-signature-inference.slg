import sollang.compiler.llvm.text as llvm

main {
    [
        """
        double value: -> {
            value * 2
        }

        run seed: Int -> Int {
            increment value: -> {
                value + 1
            }

            seed -> increment => next
            double(next)
        }

        main {
            20 -> run => result
        }
        """,
        ~
    ] => sources!
    sources! -> llvm.emit
}
