import sys.file as file

# Verifies that structured parallel callbacks may share an immutable
# SourceText capture. The parent retains ownership and resumes after join.
scan source: file.SourceText -> [UInt8; ~] {
    [0, 1, 2, ~] => indices!
    indices! -> parallel index {
        source -> byte(UIntSize(index))
    } => bytes!
    bytes!
}

main {
    "abc" -> file.borrowText -> scan => bytes!
    "bytes=$(bytes![0]),$(bytes![1]),$(bytes![2])" -> println
}
