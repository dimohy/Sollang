import sollang.compiler.ir.typed as typedIr

main {
    [
        """
        namespace sample.math
        public one: -> Int => 1
        """,
        """
        namespace app.main
        two: -> Int => 2
        main { }
        """,
        ~
    ] => sources!
    sources! -> typedIr.lower => ir!
    ir! -> each node {
        "module ir = $(node.sourceModule),$(node.kind),$(node.parent),$(node.symbol),$(node.typeOrigin),$(node.typeSymbol),$(node.operand0)" -> println
    }
}
