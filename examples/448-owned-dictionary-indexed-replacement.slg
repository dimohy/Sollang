struct OwnedValues {
    values: [Int; ~]
}

main {
    {Int: OwnedValues;
        1: { values: [10, ~] },
        2: { values: [20, 21, ~] }
    } => batches!
    OwnedValues { values: [7, 8, 9, ~] } => replacement!
    replacement! => batches![1]
    batches! -> take(1) => first!
    "replacement=$(first!.values -> len), remaining=$(batches! -> len)" -> println
}
