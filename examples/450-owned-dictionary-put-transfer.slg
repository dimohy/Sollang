struct OwnedValues {
    values: [Int; ~]
}

main {
    {Int: OwnedValues; 1: { values: [10, ~] }} => batches!
    OwnedValues { values: [7, 8, 9, ~] } => replacement!
    batches! -> put(1, replacement!)
    OwnedValues { values: [20, 21, ~] } => inserted!
    batches! -> put(2, inserted!)
    batches! -> take(1) => first!
    batches! -> take(2) => second!
    "put lengths=$(first!.values -> len),$(second!.values -> len); remaining=$(batches! -> len)" -> println
}
