import sollang.compiler.llvm.text as llvm

# Verifies pointer ABI and projected-address returns for self-host ref T.
main {
    [
        """
        struct Pair {
            first: Int
            second: Int
        }

        second pair: ref Pair -> ref Int {
            pair.second
        }

        read value: ref Int -> Int {
            value
        }

        main { }
        """,
        ~
    ] => sources!
    sources! -> llvm.emitLinux
}
