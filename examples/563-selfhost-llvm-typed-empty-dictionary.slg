import sollang.compiler.llvm.text as llvm

# Verifies a typed empty dictionary keeps capacity and can mutate without division by zero.
main {
    [
        """
        main {
            {Int: Int; 4~} => values!
            values! -> put(1, 10)
            values![1] == 10 -> if {
                "typed-empty-dictionary" -> println
            }
        }
        """,
        ~,
    ] => sources!
    sources! -> llvm.emit
}
