import sollang.compiler.llvm.text as llvm

main {
    [
        """
        same left: Int, right: Int, label: Text -> Bool => left == right

        main {
            1 => value
            (true and not (value -> same(2, "marker"))) -> if {
                "different" -> println
            }
        }
        """,
        ~
    ] => sources!
    sources! -> llvm.emit
}
