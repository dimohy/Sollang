import sollang.compiler.llvm.text as llvm

main {
    [
        """
        zero: -> UInt64 => UInt64(0)

        valueOrZero value: Option<UInt64> -> UInt64 => value -> when {
            Some(actual) { actual }
            None { zero }
        }

        main {}
        """,
        ~
    ] => sources!
    sources! -> llvm.emit
}
