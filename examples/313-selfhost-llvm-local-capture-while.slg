import sollang.compiler.llvm.text as llvm

main {
    [
        """
        outer values: [Int; ~] -> Int {
            inner limit: Int -> Int {
                0 => index!
                (index! < (values -> len) and index! < limit) -> while {
                    index! + 1 => index!
                }
                index!
            }
            2 -> inner
        }

        main { }
        """,
        ~
    ] => sources!
    sources! -> llvm.emit
}
