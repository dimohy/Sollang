import sollang.compiler.ast as ast
import sollang.compiler.lexer as lexer
import sollang.compiler.parser as parser
import sys.file as file

main {
    "examples/01-function-basic-hello.slg" -> file.mapText => source!
    source! -> lexer.lexSource => tokens!
    source! -> parser.parseSourceEvents => events!
    source! -> ast.lowerSource => nodes!

    "mapped syntax = $(tokens! -> len),$(events! -> len),$(nodes! -> len)" -> println
}
