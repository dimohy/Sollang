namespace sample.owned_keys

public struct OwnedKey {
    id: Int
    payload: [Int; ~]
}

trait Hash {
    hash: self -> Int
}

trait Eq {
    eq: self -> Int
}

impl Hash for OwnedKey {
    hash: self -> Int {
        self.id
    }
}

impl Eq for OwnedKey {
    eq: self -> Int {
        self.id
    }
}
