struct OwnedValues {
    values: [Int; ~]
}

main {
    [OwnedValues; { values: [1, ~] }, { values: [2, 3, ~] }, ~] => batches!
    OwnedValues { values: [7, 8, 9, ~] } => replacement!
    replacement! => batches![0]
    batches! -> take(0) => first!
    "replacement=$(first!.values -> len), remaining=$(batches! -> len)" -> println
}
