import sollang.compiler.ast as ast

main {
    """
    double value: -> {
        value * 2
    }

    main {
        double(20) => result
    }
    """ => source
    source -> ast.lower => nodes!
    0 => index!
    index! < (nodes! -> len) -> while {
        nodes![index!] => node
        node.kind == 7 -> if {
            "function flags = $(node.flags),types=$(node.secondaryToken),$(node.tertiaryToken)" -> println
        }
        index! + 1 => index!
    }
}
