import sys.path as path
import sys.file as file

main {
    "examples/fixtures/425-directory-order/Alpha.txt" -> path.fromText(path.nativeStyle) => sourcePath!
    sourcePath! -> file.mapPath => source!
    (source! -> len) == UIntSize(6) -> if { "native path map ok" } else { "native path map failed" } -> println
}
