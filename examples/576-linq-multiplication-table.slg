# Prints a multiplication table from lazy ranges and an open module import.
import std.sequence

main {
    2..9
        -> beforeEach dan {
            "$(dan)단" -> println
        }
        -> flatMap(1..9) dan, multiplier {
            "$dan × $multiplier = $(dan * multiplier)"
        }
        -> each line {
            line -> println
        }
}
