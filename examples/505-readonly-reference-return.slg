# Verifies that ref T uses a real readonly pointer ABI and that a returned
# field reference can be read transparently by its caller.
struct Pair {
    first: Int
    second: Int
}

first pair: ref Pair -> ref Int {
    pair.first
}

main {
    Pair { first: 41, second: 1 } => pair
    pair -> first => borrowed
    "borrowed=$(borrowed)" -> println
}
