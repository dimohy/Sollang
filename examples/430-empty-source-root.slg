import sollang.compiler.source_root as sourceRoot
import sys.path as path

main {
    "examples/fixtures/430-empty-source-root" -> path.fromText(path.nativeStyle) => root!
    root! -> sourceRoot.discover -> when {
        Ok(sources) => false
        Err(error) => true
    } => rejected
    rejected -> if { "empty source root rejected" } else { "empty source root accepted" } -> println
}
