import sollang.compiler.llvm.text as llvm

# Verifies ordinary zero-input Bool tests and the generated-style native harness in self-host LLVM.
main {
    [
        """
        test_addition: -> Bool => 20 + 22 == 42
        test_subtraction: -> Bool => 44 - 2 == 42

        main {
            0 => failures!
            "running 2 tests" -> println
            test_addition -> if {
                "test test_addition ... ok" -> println
            } else {
                "test test_addition ... FAILED" -> println
                failures! + 1 => failures!
            }
            test_subtraction -> if {
                "test test_subtraction ... ok" -> println
            } else {
                "test test_subtraction ... FAILED" -> println
                failures! + 1 => failures!
            }
            "test result: $(2 - failures!) passed; $(failures!) failed" -> println
        }
        """,
        ~
    ] => sources!
    sources! -> llvm.emit
}
