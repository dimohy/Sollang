select seed: Int -> Int {
    local value: Int -> Int {
        [value, value + 1, ~] => owned
        value > 0 -> if {
            owned[1] -> return
        }
        owned[0]
    }

    seed -> local
}

main {
    7 -> select => positive
    0 -> select => zero
    "local return = $positive,$zero" -> println
}
