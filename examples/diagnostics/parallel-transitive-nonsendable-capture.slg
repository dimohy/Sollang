# Verifies that a local helper cannot hide an Arena capture from the reference
# compiler's production parallel-callback safety check.

inspect seed: Int -> [Int; ~] {
    addUsage value: Int -> Int {
        value + Int(memory -> used)
    }

    Arena(8) => memory
    [1, 2, 3, ~] => values!
    values! -> parallel value {
        value -> addUsage
    } => shifted!
    shifted!
}

main {
    0 -> inspect => shifted!
}
