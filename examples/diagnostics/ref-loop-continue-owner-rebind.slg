# Rebinding before continue invalidates a ref used on the next iteration.
struct Pair {
    first: Int
    second: Int
}

same value: ref Int -> ref Int {
    value
}

read value: ref Int -> Int {
    value
}

main {
    Pair { first: 10, second: 20 } => pair!
    pair!.first -> same => borrowed
    0 => iteration!
    iteration! < 2 -> while {
        borrowed -> read => current
        Pair { first: 30, second: 40 } => pair!
        iteration! + 1 => iteration!
        continue
    }
}
