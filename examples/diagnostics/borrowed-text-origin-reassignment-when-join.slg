import sys.file as file

prefix source: file.SourceText -> Text => source -> slice(UIntSize(0), UIntSize(3))
consume source: move file.SourceText -> Unit {
}

main {
    "lexer" -> file.borrowText => left!
    "parser" -> file.borrowText => right!
    left! -> prefix => view!
    when {
        true { right! -> prefix => view! }
        else { "kept" -> println }
    }
    right! -> consume
    view! -> println
}
