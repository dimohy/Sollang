struct OwnedKey {
    id: Int
    payload: box Int
}

trait Hash {
    hash: self -> Int
}

trait Eq {
    eq: self -> Int
}

impl Hash for OwnedKey {
    hash: self -> Int => self.id
}

impl Eq for OwnedKey {
    eq: self -> Int => self.id
}

main {
    {OwnedKey: Int; { id: 1, payload: box 10 }: 100} => values!
    OwnedKey { id: 2, payload: box 20 } => insertedKey!
    values! -> put(insertedKey!, 200)
    insertedKey!.id => invalid
}
