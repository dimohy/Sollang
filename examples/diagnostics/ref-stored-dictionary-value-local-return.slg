# Returning a dictionary that stores a reference to a callee-local owner is unsafe.
enum IntView {
    Empty
    Ref(ref Int)
}

same value: ref Int -> ref Int {
    value
}

escape: -> {Int: IntView} {
    10 => local
    {1: IntView.Ref(local -> same)}
}

main {
    escape => escaped
    escaped -> println
}
