# Moving an owner conflicts while an element ref still has a later use.
same value: ref Int -> ref Int {
    value
}

read value: ref Int -> Int {
    value
}

consume values: move [Int; ~] -> Unit {
}

main {
    [10, 20, ~] => values!
    values![0] -> same => borrowed
    values! -> consume
    borrowed -> read -> println
}
