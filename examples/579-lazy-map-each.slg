project<T, R> values: [T; ~] -> stream R block item: T -> R {
    values -> each item {
        item -> yield -> emit
    }
}

main {
    [1, 2, 3, ~] => values!
    values!
        -> project number {
            "project=$number" -> println
            number * 10
        }
        -> each mapped {
            "mapped=$mapped" -> println
            break
        }
}
