# Verifies that a mutable owner may change after its readonly reference's last use.
struct Pair {
    first: Int
}

first pair: ref Pair -> ref Int {
    pair.first
}

main {
    Pair { first: 41 } => pair!
    pair! -> first => borrowed
    "$(borrowed)" -> println

    # The inferred loan ends above, so this field mutation is safe.
    42 => pair!.first
    "$(pair!.first)" -> println
}
