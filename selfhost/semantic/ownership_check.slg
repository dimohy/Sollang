                    # Calls inside a parallel callback may delegate to local
                    # helpers. Follow that call graph so a helper cannot hide
                    # a mutable outer binding from the concurrency boundary.
                    [Int; ~] => pendingCaptureFunctions!
                    [Int; ~] => visitedCaptureFunctions!
                    0 => parallelCallSearch!
                    parallelCallSearch! < (typed -> len) -> while {
                        typed[parallelCallSearch!] => nestedParallelCall
                        (parallelCallSearch! != parallelIrIndex! and nestedParallelCall.kind == 6 and nestedParallelCall.sourceModule == parallelCall.sourceModule and nestedParallelCall.astNode >= 0 and nestedParallelCall.targetModule >= 0 and nestedParallelCall.symbol >= 0) -> if {
                            prepared.package.nodes[parallelRange.astStart + nestedParallelCall.astNode] => nestedParallelCallAst
                            nestedParallelCallAst.parent => nestedParallelAncestor!
                            false => nestedCallInsideParallel!
                            (nestedParallelAncestor! >= 0 and not nestedCallInsideParallel!) -> while {
                                nestedParallelAncestor! == parallelCall.astNode -> if { true => nestedCallInsideParallel! } else { prepared.package.nodes[parallelRange.astStart + nestedParallelAncestor!].parent => nestedParallelAncestor! }
                            }
                            (nestedCallInsideParallel! and nestedParallelCallAst.start >= parallelName.span.start + parallelName.span.length) -> if {
                                -1 => nestedTargetFunction!
                                0 => nestedTargetSearch!
                                nestedTargetSearch! < (typed -> len) -> while {
                                    typed[nestedTargetSearch!] => nestedTargetCandidate
                                    (nestedTargetCandidate.kind == 0 and nestedTargetCandidate.sourceModule == nestedParallelCall.targetModule and nestedTargetCandidate.symbol == nestedParallelCall.symbol) -> if { nestedTargetSearch! => nestedTargetFunction! }
                                    nestedTargetSearch! + 1 => nestedTargetSearch!
