                    0 => pendingCaptureFunctionIndex!
                    pendingCaptureFunctionIndex! < (pendingCaptureFunctions! -> len) -> while {
                        pendingCaptureFunctions![pendingCaptureFunctionIndex!] => captureFunctionIr
                        false => captureFunctionVisited!
                        0 => visitedCaptureFunctionIndex!
                        visitedCaptureFunctionIndex! < (visitedCaptureFunctions! -> len) -> while {
                            visitedCaptureFunctions![visitedCaptureFunctionIndex!] == captureFunctionIr -> if { true => captureFunctionVisited! }
                            visitedCaptureFunctionIndex! + 1 => visitedCaptureFunctionIndex!
