                        not captureFunctionVisited! -> if {
                            visitedCaptureFunctions! -> push(captureFunctionIr)
                            0 => functionCaptureSearch!
                            functionCaptureSearch! < (typed -> len) -> while {
                                typed[functionCaptureSearch!] => functionCaptureNode
                                (functionCaptureSearch! -> nodeBelongsTo(captureFunctionIr)) -> if {
                                    functionCaptureNode.kind == 5 -> if {
                                        -1 => functionCaptureBindingIndex!
                                        (functionCaptureNode.operand0 >= 0 and functionCaptureNode.operand0 < (typed -> len)) -> if {
