namespace sollang.compiler.semantic.ownership_check

import sollang.compiler.ast as ast
import sollang.compiler.ir.typed as typedIr
import sollang.compiler.lexer as lexer
import sollang.compiler.semantic.context as semanticContext
import sollang.compiler.syntax as syntax
import syntax.generated.slg as grammar

public struct OwnershipDiagnostic {
    code: Int
    sourceModule: Int
    functionSymbol: Int
    expectedOrigin: Int
    expectedModule: Int
    expectedSymbol: Int
    actualOrigin: Int
    actualModule: Int
    actualSymbol: Int
    actualBuiltin: Int
    span: syntax.SourceSpan
}

struct BorrowedTextReturn {
    sourceModule: Int
    functionSymbol: Int
    parameterOrdinal: Int
}

struct BorrowedTextBinding {
    bindingIr: Int
    ownerBindingIr: Int
    ownerPlaceIr: Int
}

# Code 17 identifies whole-owner or overlapping-field use after a partial move.
# Code 18 identifies a mutable binding captured by a parallel callback.
# Code 19 identifies a structurally non-sendable parallel callback capture.
# Code 20 identifies a branch or loop that exits with a partially moved path.
# Code 21 identifies an origin moved while a returned borrowed Text is live.
# Code 22 identifies a readonly-reference argument without stable storage.
# The view region ends at its last typed-IR use rather than at lexical scope end.
public analyze sources: [Text; ~] -> [OwnershipDiagnostic; ~] {
    sources -> semanticContext.prepare => prepared
    prepared -> analyzeContext
}

public analyzeContext prepared: semanticContext.SemanticSnapshot -> [OwnershipDiagnostic; ~] {
    prepared -> typedIr.lowerContext => typed
    prepared -> analyzeLoweredContext(typed)
}

# Ownership is a read-only consumer of the canonical typed IR. The compiler
# driver lowers once and shares the same value with validation and LLVM output.
public analyzeLoweredContext prepared: semanticContext.SemanticSnapshot, typed: [typedIr.TypedIrNode; ~] -> [OwnershipDiagnostic; ~] {
    moveRegionFor nodeIndex: Int -> Int {
        typed[nodeIndex].parent => region!
        (region! >= 0 and typed[region!].kind != 1 and typed[region!].kind != 11 and typed[region!].kind != 19 and typed[region!].kind != 20) -> while {
            typed[region!].parent => region!
        }
        region!
    }
    nodeBelongsTo nodeIndex: Int, ancestorIndex: Int -> Bool {
        nodeIndex => ancestor!
        false => belongs!
        (ancestor! >= 0 and not belongs!) -> while {
            ancestor! == ancestorIndex -> if {
                true => belongs!
            } else {
                typed[ancestor!].parent => ancestor!
            }
        }
        belongs!
    }
    # Structured parallel callbacks borrow captures and join before the parent
    # resumes. SourceText is an immutable shared view here (Sync-like), not an
    # async ownership transfer (Send-like). Other affine runtime owners remain
    # rejected, including Arena, Arguments, and mapped byte views.
    captureBindingIsParallelShareable bindingIndex: Int -> Bool {
        typed[bindingIndex] => binding
        [Int; ~] => pendingTypes!
        [Int; ~] => visitedTypes!
        true => shareable!
        binding.typeId >= 0 -> if {
            pendingTypes! -> push(binding.typeId)
        } else {
            (binding.typeOrigin == 1 and (binding.typeSymbol == 15 or binding.typeSymbol == 16 or binding.typeSymbol == 17 or binding.typeSymbol == 18)) -> if { false => shareable! }
        }
        0 => pendingTypeIndex!
        (shareable! and pendingTypeIndex! < (pendingTypes! -> len)) -> while {
            pendingTypes![pendingTypeIndex!] => pendingTypeId
            false => typeVisited!
            0 => visitedTypeIndex!
            visitedTypeIndex! < (visitedTypes! -> len) -> while {
                visitedTypes![visitedTypeIndex!] == pendingTypeId -> if { true => typeVisited! }
                visitedTypeIndex! + 1 => visitedTypeIndex!
            }
            not typeVisited! -> if {
                visitedTypes! -> push(pendingTypeId)
                (pendingTypeId < 0 or pendingTypeId >= (prepared.semantic.types -> len)) -> if {
                    false => shareable!
                } else {
                    prepared.semantic.types[pendingTypeId] => pendingType
                    pendingType.status != 0 -> if { false => shareable! } else {
                        pendingType.kind == 1 -> if {
                            pendingType.origin == 1 -> if {
                                (pendingType.symbol == 15 or pendingType.symbol == 16 or pendingType.symbol == 17 or pendingType.symbol == 18) -> if { false => shareable! }
                            } else {
                                (pendingType.origin == 0 or pendingType.origin == 2) -> if {
                                    0 => fieldIndex!
                                    fieldIndex! < (prepared.semantic.fields -> len) -> while {
                                        prepared.semantic.fields[fieldIndex!] => field
                                        (field.status == 0 and field.ownerType == pendingTypeId) -> if { pendingTypes! -> push(field.fieldType) }
                                        fieldIndex! + 1 => fieldIndex!
                                    }
                                } else { false => shareable! }
                            }
                        } else {
                            (pendingType.kind == 3 or pendingType.kind == 4 or pendingType.kind == 6) -> if {
                                pendingTypes! -> push(pendingType.first)
                            } else {
                                pendingType.kind == 5 -> if {
                                    pendingTypes! -> push(pendingType.first)
                                    pendingTypes! -> push(pendingType.second)
                                } else { false => shareable! }
                            }
                        }
                    }
                }
            }
            pendingTypeIndex! + 1 => pendingTypeIndex!
        }
        shareable!
    }
    sameBindingName leftIndex: Int, rightIndex: Int -> Bool {
        typed[leftIndex] => left
        typed[rightIndex] => right
        false => same!
        (left.sourceModule == right.sourceModule and left.payloadToken >= 0 and right.payloadToken >= 0) -> if {
            prepared.package.ranges[left.sourceModule] => nameRange
            prepared.package.tokens[nameRange.tokenStart + left.payloadToken] => leftName
            prepared.package.tokens[nameRange.tokenStart + right.payloadToken] => rightName
            leftName.span.length == rightName.span.length => same!
            UIntSize(0) => nameByte!
            (same! and nameByte! < leftName.span.length) -> while {
                (prepared.package.sources[left.sourceModule] -> byte(leftName.span.start + nameByte!)) != (prepared.package.sources[right.sourceModule] -> byte(rightName.span.start + nameByte!)) -> if {
                    false => same!
                }
                nameByte! + UIntSize(1) => nameByte!
            }
        }
        same!
    }
    placeRootBinding placeIr: Int -> Int {
        placeIr => root!
        (root! >= 0 and (typed[root!].kind == 13 or typed[root!].kind == 15)) -> while {
            typed[root!].operand0 => root!
        }
        (root! >= 0 and typed[root!].kind == 5 and typed[root!].operand0 >= 0) -> if {
            typed[root!].operand0
        } else { -1 }
    }
    placeProjectionDepth placeIr: Int -> Int {
        placeIr => projected!
        0 => depth!
        (projected! >= 0 and (typed[projected!].kind == 13 or typed[projected!].kind == 15)) -> while {
            depth! + 1 => depth!
            typed[projected!].operand0 => projected!
        }
        depth!
    }
    placeProjectionAt placeIr: Int, ordinal: Int -> Int {
        placeIr -> placeProjectionDepth => depth
        placeIr => projected!
        depth - 1 => currentOrdinal!
        (projected! >= 0 and currentOrdinal! > ordinal) -> while {
            typed[projected!].operand0 => projected!
            currentOrdinal! - 1 => currentOrdinal!
        }
        projected!
    }
    tokenTextEquals leftModule: Int, leftToken: Int, rightModule: Int, rightToken: Int -> Bool {
        false => same!
        (leftModule >= 0 and rightModule >= 0 and leftToken >= 0 and rightToken >= 0) -> if {
            prepared.package.ranges[leftModule] => leftRange
            prepared.package.ranges[rightModule] => rightRange
            prepared.package.tokens[leftRange.tokenStart + leftToken] => left
            prepared.package.tokens[rightRange.tokenStart + rightToken] => right
            left.span.length == right.span.length => same!
            UIntSize(0) => byteIndex!
            (same! and byteIndex! < left.span.length) -> while {
                (prepared.package.sources[leftModule] -> byte(left.span.start + byteIndex!)) != (prepared.package.sources[rightModule] -> byte(right.span.start + byteIndex!)) -> if {
                    false => same!
                }
                byteIndex! + UIntSize(1) => byteIndex!
            }
        }
        same!
    }
    placesOverlap leftPlaceIr: Int, rightPlaceIr: Int -> Bool {
        leftPlaceIr -> placeProjectionDepth => leftDepth
        rightPlaceIr -> placeProjectionDepth => rightDepth
        rightDepth => sharedDepth!
        leftDepth < rightDepth -> if { leftDepth => sharedDepth! }
        true => overlap!
        0 => ordinal!
        (overlap! and ordinal! < sharedDepth!) -> while {
            leftPlaceIr -> placeProjectionAt(ordinal!) => leftProjectionIr
            rightPlaceIr -> placeProjectionAt(ordinal!) => rightProjectionIr
            typed[leftProjectionIr] => leftProjection
            typed[rightProjectionIr] => rightProjection
            leftProjection.kind != rightProjection.kind -> if {
                # A field and an index cannot prove separate storage.
            } else {
                leftProjection.kind == 13 -> if {
                    (leftProjection.symbol >= 0 and rightProjection.symbol >= 0 and (leftProjection.targetModule != rightProjection.targetModule or leftProjection.symbol != rightProjection.symbol)) -> if {
                        false => overlap!
                    }
                } else {
                    leftProjection.kind == 15 -> if {
                        (leftProjection.operand1 >= 0 and rightProjection.operand1 >= 0 and typed[leftProjection.operand1].kind == 3 and typed[rightProjection.operand1].kind == 3) -> if {
                            typed[leftProjection.operand1] => leftIndex
                            typed[rightProjection.operand1] => rightIndex
                            leftIndex.sourceModule -> tokenTextEquals(leftIndex.payloadToken, rightIndex.sourceModule, rightIndex.payloadToken) => sameIndex
                            not sameIndex -> if { false => overlap! }
                        }
                    }
                }
            }
            ordinal! + 1 => ordinal!
        }
        overlap!
    }
    placeOverlapsIndexedProjection placeIr: Int, indexIr: Int -> Bool {
        placeIr -> placeProjectionDepth => depth
        true => overlap!
        depth > 0 -> if {
            placeIr -> placeProjectionAt(0) => projectionIr
            typed[projectionIr] => projection
            (projection.kind == 15 and projection.operand1 >= 0 and indexIr >= 0 and typed[projection.operand1].kind == 3 and typed[indexIr].kind == 3) -> if {
                typed[projection.operand1] => borrowedIndex
                typed[indexIr] => accessedIndex
                borrowedIndex.sourceModule -> tokenTextEquals(borrowedIndex.payloadToken, accessedIndex.sourceModule, accessedIndex.payloadToken) => sameIndex
                not sameIndex -> if { false => overlap! }
            }
        }
        overlap!
    }
    nodeHasTakeOperation nodeIndex: Int -> Bool {
        false => hasTake!
        typed[nodeIndex] => candidate
        (candidate.sourceModule >= 0 and candidate.astNode >= 0) -> if {
            prepared.package.ranges[candidate.sourceModule] => candidateRange
            prepared.package.nodes[candidateRange.astStart + candidate.astNode] => candidateAst
            candidateAst.firstToken => tokenIndex!
            (not hasTake! and tokenIndex! < candidateAst.firstToken + candidateAst.tokenCount) -> while {
                prepared.package.tokens[candidateRange.tokenStart + tokenIndex!] => token
                (token.kind == grammar.tokenIdIdentifier and token.span.length == UIntSize(4)) -> if {
                    ((prepared.package.sources[candidate.sourceModule] -> byte(token.span.start)) == UInt8(116) and (prepared.package.sources[candidate.sourceModule] -> byte(token.span.start + UIntSize(1))) == UInt8(97) and (prepared.package.sources[candidate.sourceModule] -> byte(token.span.start + UIntSize(2))) == UInt8(107) and (prepared.package.sources[candidate.sourceModule] -> byte(token.span.start + UIntSize(3))) == UInt8(101)) -> if {
                        true => hasTake!
                    }
                }
                tokenIndex! + 1 => tokenIndex!
            }
        }
        hasTake!
    }
    borrowedBindingUsedAfterSite bindingIr: Int, siteIr: Int -> Bool {
        false => used!
        prepared.package.ranges[typed[siteIr].sourceModule] => useRange
        prepared.package.nodes[useRange.astStart + typed[siteIr].astNode].start => siteStart
        0 => useIndex!
        (not used! and useIndex! < (typed -> len)) -> while {
            typed[useIndex!] => use
            (use.kind == 5 and use.sourceModule == typed[siteIr].sourceModule and use.astNode >= 0 and use.operand0 == bindingIr) -> if {
                prepared.package.nodes[useRange.astStart + use.astNode].start > siteStart -> if {
                    siteIr -> useReachableAfterMove(useIndex!) -> if { true => used! }
                }
            }
            useIndex! + 1 => useIndex!
        }
        used!
    }
    enclosingLoopFor nodeIndex: Int -> Int {
        nodeIndex => ancestor!
        -1 => loop!
        (ancestor! >= 0 and loop! < 0) -> while {
            typed[ancestor!].kind == 20 -> if {
                ancestor! => loop!
            } else {
                typed[ancestor!].parent => ancestor!
            }
        }
        loop!
    }
    mutuallyExclusiveBranches leftIndex: Int, rightIndex: Int -> Bool {
        leftIndex => leftAncestor!
        false => exclusive!
        (leftAncestor! >= 0 and not exclusive!) -> while {
            typed[leftAncestor!].parent => branchControl!
            (typed[leftAncestor!].kind == 19 and typed[leftAncestor!].operand1 >= 0 and typed[leftAncestor!].nextOperand >= 0) -> if {
                leftIndex -> nodeBelongsTo(typed[leftAncestor!].operand1) => leftInArm
                leftIndex -> nodeBelongsTo(typed[leftAncestor!].nextOperand) => leftInAlternative
                rightIndex -> nodeBelongsTo(typed[leftAncestor!].operand1) => rightInArm
                rightIndex -> nodeBelongsTo(typed[leftAncestor!].nextOperand) => rightInAlternative
                ((leftInArm and rightInAlternative) or (leftInAlternative and rightInArm)) -> if {
                    true => exclusive!
                }
            }
            (typed[leftAncestor!].kind == 19 and branchControl! >= 0 and (typed[branchControl!].kind == 18 or typed[branchControl!].kind == 27)) -> if {
                rightIndex => rightAncestor!
                (rightAncestor! >= 0 and typed[rightAncestor!].parent != branchControl!) -> while {
                    typed[rightAncestor!].parent => rightAncestor!
                }
                (rightAncestor! >= 0 and typed[rightAncestor!].kind == 19 and typed[rightAncestor!].parent == branchControl! and rightAncestor! != leftAncestor!) -> if {
                    true => exclusive!
                }
            }
            typed[leftAncestor!].parent => leftAncestor!
        }
        exclusive!
    }
    useReachableAfterMove moveIndex: Int, useIndex: Int -> Bool {
        moveIndex -> enclosingLoopFor => moveLoop
        (moveLoop >= 0 and (useIndex -> nodeBelongsTo(moveLoop))) -> if {
            true
        } else {
            moveIndex -> mutuallyExclusiveBranches(useIndex) -> if {
                false
            } else {
                prepared.package.ranges[typed[moveIndex].sourceModule] => reachabilityRange
                prepared.package.nodes[reachabilityRange.astStart + typed[useIndex].astNode].start > prepared.package.nodes[reachabilityRange.astStart + typed[moveIndex].astNode].start
            }
        }
    }
    enclosingAlternativeControl nodeIndex: Int -> Int {
        nodeIndex => ancestor!
        -1 => control!
        (ancestor! >= 0 and control! < 0) -> while {
            typed[ancestor!].kind == 19 -> if {
                typed[ancestor!].parent => candidateControl!
                (candidateControl! >= 0 and (typed[candidateControl!].kind == 18 or typed[candidateControl!].kind == 27 or (typed[candidateControl!].kind == 19 and typed[candidateControl!].operand1 >= 0 and typed[candidateControl!].nextOperand >= 0))) -> if {
                    candidateControl! => control!
                } else {
                    typed[ancestor!].parent => ancestor!
                }
            } else {
                typed[ancestor!].parent => ancestor!
            }
        }
        control!
    }
    alternativeRebindsBefore regionIndex: Int, definitionIndex: Int, beforeStart: UIntSize -> Bool {
        false => rebinds!
        0 => candidateIndex!
        candidateIndex! < (typed -> len) -> while {
            typed[candidateIndex!] => candidate
            (candidate.kind == 17 and candidate.astNode >= 0 and (candidateIndex! -> nodeBelongsTo(regionIndex)) and (definitionIndex -> sameBindingName(candidateIndex!))) -> if {
                prepared.package.ranges[candidate.sourceModule] => candidateRange
                prepared.package.nodes[candidateRange.astStart + candidate.astNode].start < beforeStart -> if {
                    true => rebinds!
                }
            }
            candidateIndex! + 1 => candidateIndex!
        }
        rebinds!
    }
    linkedAlternativesRebindBefore controlIndex: Int, definitionIndex: Int, beforeStart: UIntSize -> Bool {
        typed[controlIndex] => control
        control.operand1 -> alternativeRebindsBefore(definitionIndex, beforeStart) => currentRebinds
        false => remainingRebinds!
        control.nextOperand >= 0 -> if {
            typed[control.nextOperand] => nextAlternative
            (nextAlternative.kind == 19 and nextAlternative.operand1 >= 0 and nextAlternative.nextOperand >= 0) -> if {
                control.nextOperand -> linkedAlternativesRebindBefore(definitionIndex, beforeStart) => remainingRebinds!
            } else {
                control.nextOperand -> alternativeRebindsBefore(definitionIndex, beforeStart) => remainingRebinds!
            }
        }
        currentRebinds and remainingRebinds!
    }
    allAlternativesRebindBefore controlIndex: Int, definitionIndex: Int, beforeStart: UIntSize -> Bool {
        typed[controlIndex] => control
        (control.kind == 18 and control.operand1 >= 0 and control.nextOperand >= 0) -> if {
            control.operand1 -> alternativeRebindsBefore(definitionIndex, beforeStart) => thenRebinds
            control.nextOperand -> alternativeRebindsBefore(definitionIndex, beforeStart) => elseRebinds
            thenRebinds and elseRebinds
        } else {
            (control.kind == 19 and control.operand1 >= 0 and control.nextOperand >= 0) -> if {
                controlIndex -> linkedAlternativesRebindBefore(definitionIndex, beforeStart)
            } else { false }
        }
    }
    memberMoveMatchesAssignment moveIndex: Int, assignmentIndex: Int -> Bool {
        moves![moveIndex] => candidateMove
        typed[assignmentIndex] => candidateAssignment
        false => matches!
        (candidateMove.memberIr >= 0 and candidateAssignment.kind == 25 and candidateAssignment.sourceModule == candidateMove.sourceModule and candidateAssignment.symbol == candidateMove.symbol) -> if {
            typed[candidateMove.memberIr] => candidateMember
            prepared.package.ranges[candidateMember.sourceModule] => candidateRange
            prepared.package.nodes[candidateRange.astStart + candidateMember.astNode] => candidateMemberAst
            prepared.package.nodes[candidateRange.astStart + candidateAssignment.astNode] => candidateAssignmentAst
            -1 => movedFieldToken!
            0 => movedIdentifierCount!
            candidateMemberAst.firstToken => movedTokenIndex!
            movedTokenIndex! < candidateMemberAst.firstToken + candidateMemberAst.tokenCount -> while {
                prepared.package.tokens[candidateRange.tokenStart + movedTokenIndex!].kind == grammar.tokenIdIdentifier -> if {
                    movedTokenIndex! => movedFieldToken!
                    movedIdentifierCount! + 1 => movedIdentifierCount!
                }
                movedTokenIndex! + 1 => movedTokenIndex!
            }
            (movedIdentifierCount! == 2 and movedFieldToken! >= 0 and candidateAssignmentAst.secondaryToken >= 0) -> if {
                prepared.package.tokens[candidateRange.tokenStart + movedFieldToken!] => movedField
                prepared.package.tokens[candidateRange.tokenStart + candidateAssignmentAst.secondaryToken] => assignedField
                movedField.span.length == assignedField.span.length => matches!
                UIntSize(0) => fieldByte!
                (matches! and fieldByte! < movedField.span.length) -> while {
                    (prepared.package.sources[candidateMember.sourceModule] -> byte(movedField.span.start + fieldByte!)) != (prepared.package.sources[candidateAssignment.sourceModule] -> byte(assignedField.span.start + fieldByte!)) -> if { false => matches! }
                    fieldByte! + UIntSize(1) => fieldByte!
                }
            }
        }
        matches!
    }
    moveReinitializedBefore moveIndex: Int, beforeStart: UIntSize -> Bool {
        moves![moveIndex] => candidateMove
        prepared.package.ranges[candidateMove.sourceModule] => candidateRange
        prepared.package.nodes[candidateRange.astStart + typed[candidateMove.siteIr].astNode].start => moveStart
        false => repaired!
        0 => assignmentSearch!
        assignmentSearch! < (typed -> len) -> while {
            typed[assignmentSearch!] => reinitialization
            (reinitialization.kind == 25 and (assignmentSearch! -> moveRegionFor) == candidateMove.regionIr and moveStart < prepared.package.nodes[candidateRange.astStart + reinitialization.astNode].start and prepared.package.nodes[candidateRange.astStart + reinitialization.astNode].start < beforeStart) -> if {
                moveIndex -> memberMoveMatchesAssignment(assignmentSearch!) -> if { true => repaired! }
            }
            assignmentSearch! + 1 => assignmentSearch!
        }
        repaired!
    }
    typed -> typedIr.movesFrom => moves!
    [OwnershipDiagnostic; ~] => diagnostics!

    # A value passed to ref T must already be a reference or resolve to an
    # immutable binding place. Literals, constructor results, and call results
    # are temporaries and cannot become the origin of a returned reference.
    0 => referenceCallIndex!
    referenceCallIndex! < (typed -> len) -> while {
        typed[referenceCallIndex!] => referenceCall
        (referenceCall.kind == 6 and referenceCall.targetModule >= 0 and referenceCall.symbol >= 0 and referenceCall.operand0 >= 0) -> if {
            -1 => referenceTargetFunction!
            0 => referenceTargetSearch!
            referenceTargetSearch! < (typed -> len) -> while {
                typed[referenceTargetSearch!] => referenceTargetCandidate
                (referenceTargetCandidate.kind == 0 and referenceTargetCandidate.sourceModule == referenceCall.targetModule and referenceTargetCandidate.symbol == referenceCall.symbol) -> if {
                    referenceTargetSearch! => referenceTargetFunction!
                }
                referenceTargetSearch! + 1 => referenceTargetSearch!
            }
            referenceTargetFunction! >= 0 -> if {
                typed[referenceTargetFunction!] => referenceTarget
                referenceCall.operand0 => referenceArgumentIr!
                referenceTarget.operand1 => referenceParameterIr!
                (referenceArgumentIr! >= 0 and referenceParameterIr! >= 0) -> while {
                    typed[referenceArgumentIr!] => referenceArgument
                    typed[referenceParameterIr!] => referenceParameter
                    false => parameterIsReadonlyReference!
                    (referenceParameter.typeId >= 0 and referenceParameter.typeId < (prepared.semantic.types -> len)) -> if {
                        prepared.semantic.types[referenceParameter.typeId].kind == 8 -> if { true => parameterIsReadonlyReference! }
                    }
                    false => argumentIsReadonlyReference!
                    (referenceArgument.typeId >= 0 and referenceArgument.typeId < (prepared.semantic.types -> len)) -> if {
                        prepared.semantic.types[referenceArgument.typeId].kind == 8 -> if { true => argumentIsReadonlyReference! }
                    }
                    (parameterIsReadonlyReference! and not argumentIsReadonlyReference!) -> if {
                        referenceArgumentIr! -> placeRootBinding => referenceRootBinding
                        false => referenceAddressable!
                        referenceRootBinding >= 0 -> if {
                            typed[referenceRootBinding] => referenceRoot
                            (referenceRoot.kind == 10 or referenceRoot.kind == 17) -> if { true => referenceAddressable! }
                        }
                        not referenceAddressable! -> if {
                            prepared.package.ranges[referenceArgument.sourceModule] => referenceArgumentRange
                            prepared.package.nodes[referenceArgumentRange.astStart + referenceArgument.astNode] => referenceArgumentAst
                            diagnostics! -> push(OwnershipDiagnostic {
                                code: 22
                                sourceModule: referenceArgument.sourceModule
                                functionSymbol: referenceCall.symbol
                                expectedOrigin: -1
                                expectedModule: referenceCall.targetModule
                                expectedSymbol: referenceParameter.symbol
                                actualOrigin: referenceArgument.typeOrigin
                                actualModule: referenceArgument.typeModule
                                actualSymbol: referenceArgument.typeSymbol
                                actualBuiltin: referenceArgument.typeSymbol
                                span: syntax.SourceSpan { fileId: referenceArgument.sourceModule, start: referenceArgumentAst.start, length: referenceArgumentAst.length }
                            })
                        }
                    }
                    typed[referenceArgumentIr!].nextOperand => referenceArgumentIr!
                    referenceParameterIr! == referenceTarget.operand1 -> if {
                        referenceTarget.nextOperand => referenceParameterIr!
                    } else { typed[referenceParameterIr!].nextOperand => referenceParameterIr! }
                }
            }
        }
        referenceCallIndex! + 1 => referenceCallIndex!
    }

    # A mutable owner may be borrowed, but its storage cannot change while a
    # returned readonly reference still has a reachable use.
    0 => referenceBindingIndex!
    referenceBindingIndex! < (typed -> len) -> while {
        typed[referenceBindingIndex!] => referenceBinding
        false => referenceBindingIsReadonlyReference!
        (referenceBinding.kind == 17 and referenceBinding.operand0 >= 0) -> if {
            typed[referenceBinding.operand0] => referenceBindingValue
            (referenceBindingValue.kind == 6 and referenceBindingValue.typeId >= 0 and referenceBindingValue.typeId < (prepared.semantic.types -> len)) -> if {
                prepared.semantic.types[referenceBindingValue.typeId].kind == 8 -> if { true => referenceBindingIsReadonlyReference! }
            }
        }
        referenceBindingIsReadonlyReference! -> if {
            typed[referenceBinding.operand0] => referenceCall
            (referenceCall.kind == 6 and referenceCall.operand0 >= 0) -> if {
                referenceCall.operand0 -> placeRootBinding => referenceOwnerBinding
                referenceOwnerBinding >= 0 -> if {
                    0 => referenceMutationIndex!
                    referenceMutationIndex! < (typed -> len) -> while {
                        typed[referenceMutationIndex!] => referenceMutation
                        false => mutatesReferenceOwner!
                        (referenceMutation.kind == 25 and referenceMutation.sourceModule == typed[referenceOwnerBinding].sourceModule and referenceMutation.symbol == typed[referenceOwnerBinding].symbol) -> if {
                            true => mutatesReferenceOwner!
                        }
                        (mutatesReferenceOwner! and referenceBindingIndex! < referenceMutationIndex! and (referenceBindingIndex! -> borrowedBindingUsedAfterSite(referenceMutationIndex!))) -> if {
                            prepared.package.ranges[referenceMutation.sourceModule] => referenceMutationRange
                            prepared.package.nodes[referenceMutationRange.astStart + referenceMutation.astNode] => referenceMutationAst
                            diagnostics! -> push(OwnershipDiagnostic {
                                code: 23
                                sourceModule: referenceMutation.sourceModule
                                functionSymbol: referenceCall.symbol
                                expectedOrigin: -1
                                expectedModule: referenceCall.targetModule
                                expectedSymbol: referenceOwnerBinding
                                actualOrigin: -1
                                actualModule: -1
                                actualSymbol: referenceBindingIndex!
                                actualBuiltin: -1
                                span: syntax.SourceSpan { fileId: referenceMutation.sourceModule, start: referenceMutationAst.start, length: referenceMutationAst.length }
                            })
                        }
                        referenceMutationIndex! + 1 => referenceMutationIndex!
                    }
                }
            }
        }
        referenceBindingIndex! + 1 => referenceBindingIndex!
    }

    # Semantic type children precede their owners. Classify Text containment
    # once so aggregate-origin discovery is allocation-free and target-stable.
    [Bool; ~] => borrowedTextTypes!
    0 => borrowedTextTypeIndex!
    borrowedTextTypeIndex! < (prepared.semantic.types -> len) -> while {
        prepared.semantic.types[borrowedTextTypeIndex!] => borrowedTextType
