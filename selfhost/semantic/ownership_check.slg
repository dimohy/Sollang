                prepared.package.tokens[parallelRange.tokenStart + parallelAst.payloadToken] => parallelName
                false => isParallel!
                parallelCall.opcode == -209 -> if { true => isParallel! } else { parallelName.span.length == UIntSize(8) => isParallel! }
                "parallel" => parallelText
                UIntSize(0) => parallelNameByte!
                (parallelCall.opcode == -207 and isParallel! and parallelNameByte! < parallelName.span.length) -> while {
                    (prepared.package.sources[parallelCall.sourceModule] -> byte(parallelName.span.start + parallelNameByte!)) != (parallelText -> byte(parallelNameByte!)) -> if { false => isParallel! }
                    parallelNameByte! + UIntSize(1) => parallelNameByte!
                }
                isParallel! -> if {
                    [Int; ~] => reportedMutableCaptures!
                    [Int; ~] => reportedNonSendableCaptures!
                    0 => captureUseIndex!
                    captureUseIndex! < (typed -> len) -> while {
                        typed[captureUseIndex!] => captureUse
                        (captureUse.kind == 5 and captureUse.sourceModule == parallelCall.sourceModule and captureUse.astNode >= 0) -> if {
                            prepared.package.nodes[parallelRange.astStart + captureUse.astNode] => captureUseAst
                            captureUseAst.parent => captureAncestor!
                            false => insideParallel!
                            (captureAncestor! >= 0 and not insideParallel!) -> while {
                                captureAncestor! == parallelCall.astNode -> if { true => insideParallel! } else { prepared.package.nodes[parallelRange.astStart + captureAncestor!].parent => captureAncestor! }
                            }
                            # The role source precedes its `parallel` token and
                            # stays in the parent scope; only the trailing block
                            # is a concurrently executed callback.
                            (insideParallel! and captureUseAst.start >= parallelName.span.start + parallelName.span.length) -> if {
                                -1 => captureBindingIndex!
                                (captureUse.operand0 >= 0 and captureUse.operand0 < (typed -> len)) -> if {
                                    typed[captureUse.operand0] => directCaptureBinding
                                    (directCaptureBinding.kind == 10 or directCaptureBinding.kind == 17) -> if { captureUse.operand0 => captureBindingIndex! }
                                }
                                captureBindingIndex! < 0 -> if {
                                    0 => captureBindingSearch!
                                    captureBindingSearch! < (typed -> len) -> while {
                                        typed[captureBindingSearch!] => captureBindingCandidate
                                        ((captureBindingCandidate.kind == 10 or captureBindingCandidate.kind == 17) and captureBindingCandidate.sourceModule == captureUse.sourceModule and captureBindingCandidate.symbol == captureUse.symbol) -> if {
                                            captureBindingSearch! => captureBindingIndex!
                                        }
                                        captureBindingSearch! + 1 => captureBindingSearch!
                                    }
                                }
                                captureBindingIndex! >= 0 -> if {
                                    typed[captureBindingIndex!] => captureBinding
                                    false => bindingInsideParallel!
                                    captureBinding.astNode >= 0 -> if {
                                        prepared.package.nodes[parallelRange.astStart + captureBinding.astNode].parent => bindingAncestor!
                                        (bindingAncestor! >= 0 and not bindingInsideParallel!) -> while {
                                            bindingAncestor! == parallelCall.astNode -> if { true => bindingInsideParallel! } else { prepared.package.nodes[parallelRange.astStart + bindingAncestor!].parent => bindingAncestor! }
                                        }
                                    }
                                    not bindingInsideParallel! -> if {
                                        captureBinding.flags == 1 -> if {
                                            false => mutableCaptureReported!
                                            0 => reportedMutableIndex!
                                            reportedMutableIndex! < (reportedMutableCaptures! -> len) -> while {
                                                reportedMutableCaptures![reportedMutableIndex!] == captureBindingIndex! -> if { true => mutableCaptureReported! }
                                                reportedMutableIndex! + 1 => reportedMutableIndex!
                                            }
                                            not mutableCaptureReported! -> if {
                                                reportedMutableCaptures! -> push(captureBindingIndex!)
                                                diagnostics! -> push(OwnershipDiagnostic {
                                                    code: 18
                                                    sourceModule: captureUse.sourceModule
                                                    functionSymbol: -1
                                                    expectedOrigin: -1
                                                    expectedModule: -1
                                                    expectedSymbol: -1
                                                    actualOrigin: captureBinding.typeOrigin
                                                    actualModule: captureBinding.typeModule
                                                    actualSymbol: captureBinding.typeSymbol
                                                    actualBuiltin: captureBinding.typeSymbol
                                                    span: syntax.SourceSpan { fileId: captureUse.sourceModule, start: captureUseAst.start, length: captureUseAst.length }
                                                })
                                            }
                                        } else {
                                            not (captureBindingIndex! -> captureBindingIsParallelShareable) -> if {
                                                false => nonSendableCaptureReported!
                                                0 => reportedNonSendableIndex!
                                                reportedNonSendableIndex! < (reportedNonSendableCaptures! -> len) -> while {
                                                    reportedNonSendableCaptures![reportedNonSendableIndex!] == captureBindingIndex! -> if { true => nonSendableCaptureReported! }
                                                    reportedNonSendableIndex! + 1 => reportedNonSendableIndex!
                                                }
                                                not nonSendableCaptureReported! -> if {
                                                    reportedNonSendableCaptures! -> push(captureBindingIndex!)
                                                diagnostics! -> push(OwnershipDiagnostic {
                                                    code: 19
                                                    sourceModule: captureUse.sourceModule
                                                    functionSymbol: -1
                                                    expectedOrigin: -1
                                                    expectedModule: -1
                                                    expectedSymbol: -1
                                                    actualOrigin: captureBinding.typeOrigin
                                                    actualModule: captureBinding.typeModule
                                                    actualSymbol: captureBinding.typeSymbol
                                                    actualBuiltin: captureBinding.typeSymbol
                                                    span: syntax.SourceSpan { fileId: captureUse.sourceModule, start: captureUseAst.start, length: captureUseAst.length }
                                                })
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                        captureUseIndex! + 1 => captureUseIndex!
                    }

                    # Calls inside a parallel callback may delegate to local
                    # helpers. Follow that call graph so a helper cannot hide
                    # a mutable outer binding from the concurrency boundary.
                    [Int; ~] => pendingCaptureFunctions!
                    [Int; ~] => visitedCaptureFunctions!
                    0 => parallelCallSearch!
                    parallelCallSearch! < (typed -> len) -> while {
                        typed[parallelCallSearch!] => nestedParallelCall
                        (parallelCallSearch! != parallelIrIndex! and nestedParallelCall.kind == 6 and nestedParallelCall.sourceModule == parallelCall.sourceModule and nestedParallelCall.astNode >= 0 and nestedParallelCall.targetModule >= 0 and nestedParallelCall.symbol >= 0) -> if {
                            prepared.package.nodes[parallelRange.astStart + nestedParallelCall.astNode] => nestedParallelCallAst
                            nestedParallelCallAst.parent => nestedParallelAncestor!
                            false => nestedCallInsideParallel!
                            (nestedParallelAncestor! >= 0 and not nestedCallInsideParallel!) -> while {
                                nestedParallelAncestor! == parallelCall.astNode -> if { true => nestedCallInsideParallel! } else { prepared.package.nodes[parallelRange.astStart + nestedParallelAncestor!].parent => nestedParallelAncestor! }
                            }
                            (nestedCallInsideParallel! and nestedParallelCallAst.start >= parallelName.span.start + parallelName.span.length) -> if {
                                -1 => nestedTargetFunction!
                                0 => nestedTargetSearch!
                                nestedTargetSearch! < (typed -> len) -> while {
                                    typed[nestedTargetSearch!] => nestedTargetCandidate
                                    (nestedTargetCandidate.kind == 0 and nestedTargetCandidate.sourceModule == nestedParallelCall.targetModule and nestedTargetCandidate.symbol == nestedParallelCall.symbol) -> if { nestedTargetSearch! => nestedTargetFunction! }
                                    nestedTargetSearch! + 1 => nestedTargetSearch!
                                }
                                nestedTargetFunction! >= 0 -> if { pendingCaptureFunctions! -> push(nestedTargetFunction!) }
                            }
                        }
                        parallelCallSearch! + 1 => parallelCallSearch!
                    }

                    0 => pendingCaptureFunctionIndex!
                    pendingCaptureFunctionIndex! < (pendingCaptureFunctions! -> len) -> while {
                        pendingCaptureFunctions![pendingCaptureFunctionIndex!] => captureFunctionIr
                        false => captureFunctionVisited!
                        0 => visitedCaptureFunctionIndex!
                        visitedCaptureFunctionIndex! < (visitedCaptureFunctions! -> len) -> while {
                            visitedCaptureFunctions![visitedCaptureFunctionIndex!] == captureFunctionIr -> if { true => captureFunctionVisited! }
                            visitedCaptureFunctionIndex! + 1 => visitedCaptureFunctionIndex!
                        }
                        not captureFunctionVisited! -> if {
                            visitedCaptureFunctions! -> push(captureFunctionIr)
                            0 => functionCaptureSearch!
                            functionCaptureSearch! < (typed -> len) -> while {
                                typed[functionCaptureSearch!] => functionCaptureNode
                                (functionCaptureSearch! -> nodeBelongsTo(captureFunctionIr)) -> if {
                                    functionCaptureNode.kind == 5 -> if {
                                        -1 => functionCaptureBindingIndex!
                                        (functionCaptureNode.operand0 >= 0 and functionCaptureNode.operand0 < (typed -> len)) -> if {
                                            typed[functionCaptureNode.operand0] => functionCaptureBindingCandidate
                                            (functionCaptureBindingCandidate.kind == 10 or functionCaptureBindingCandidate.kind == 17) -> if { functionCaptureNode.operand0 => functionCaptureBindingIndex! }
                                        }
                                        functionCaptureBindingIndex! < 0 -> if {
                                            0 => functionCaptureBindingSearch!
                                            functionCaptureBindingSearch! < (typed -> len) -> while {
                                                typed[functionCaptureBindingSearch!] => functionCaptureBindingCandidate
                                                ((functionCaptureBindingCandidate.kind == 10 or functionCaptureBindingCandidate.kind == 17) and functionCaptureBindingCandidate.sourceModule == functionCaptureNode.sourceModule and functionCaptureBindingCandidate.symbol == functionCaptureNode.symbol) -> if {
                                                    functionCaptureBindingSearch! => functionCaptureBindingIndex!
                                                }
                                                functionCaptureBindingSearch! + 1 => functionCaptureBindingSearch!
                                            }
                                        }
                                        (functionCaptureBindingIndex! >= 0 and not (functionCaptureBindingIndex! -> nodeBelongsTo(captureFunctionIr))) -> if {
                                            typed[functionCaptureBindingIndex!] => functionCaptureBinding
                                            functionCaptureBinding.flags == 1 -> if {
                                                false => functionMutableReported!
                                                0 => functionReportedIndex!
                                                functionReportedIndex! < (reportedMutableCaptures! -> len) -> while {
                                                    reportedMutableCaptures![functionReportedIndex!] == functionCaptureBindingIndex! -> if { true => functionMutableReported! }
                                                    functionReportedIndex! + 1 => functionReportedIndex!
                                                }
                                                not functionMutableReported! -> if {
                                                    reportedMutableCaptures! -> push(functionCaptureBindingIndex!)
                                                    prepared.package.ranges[functionCaptureNode.sourceModule] => functionCaptureRange
                                                    prepared.package.nodes[functionCaptureRange.astStart + functionCaptureNode.astNode] => functionCaptureAst
                                                    diagnostics! -> push(OwnershipDiagnostic {
                                                        code: 18
                                                        sourceModule: functionCaptureNode.sourceModule
                                                        functionSymbol: typed[captureFunctionIr].symbol
                                                        expectedOrigin: -1
                                                        expectedModule: -1
                                                        expectedSymbol: -1
                                                        actualOrigin: functionCaptureBinding.typeOrigin
                                                        actualModule: functionCaptureBinding.typeModule
                                                        actualSymbol: functionCaptureBinding.typeSymbol
                                                        actualBuiltin: functionCaptureBinding.typeSymbol
                                                        span: syntax.SourceSpan { fileId: functionCaptureNode.sourceModule, start: functionCaptureAst.start, length: functionCaptureAst.length }
                                                    })
                                                }
                                            } else {
                                                not (functionCaptureBindingIndex! -> captureBindingIsParallelShareable) -> if {
                                                    false => functionNonSendableReported!
                                                    0 => functionNonSendableReportedIndex!
                                                    functionNonSendableReportedIndex! < (reportedNonSendableCaptures! -> len) -> while {
                                                        reportedNonSendableCaptures![functionNonSendableReportedIndex!] == functionCaptureBindingIndex! -> if { true => functionNonSendableReported! }
                                                        functionNonSendableReportedIndex! + 1 => functionNonSendableReportedIndex!
                                                    }
                                                    not functionNonSendableReported! -> if {
                                                        reportedNonSendableCaptures! -> push(functionCaptureBindingIndex!)
                                                        prepared.package.ranges[functionCaptureNode.sourceModule] => functionCaptureRange
                                                        prepared.package.nodes[functionCaptureRange.astStart + functionCaptureNode.astNode] => functionCaptureAst
                                                        diagnostics! -> push(OwnershipDiagnostic {
                                                            code: 19
                                                            sourceModule: functionCaptureNode.sourceModule
                                                            functionSymbol: typed[captureFunctionIr].symbol
                                                            expectedOrigin: -1
                                                            expectedModule: -1
                                                            expectedSymbol: -1
                                                            actualOrigin: functionCaptureBinding.typeOrigin
                                                            actualModule: functionCaptureBinding.typeModule
                                                            actualSymbol: functionCaptureBinding.typeSymbol
                                                            actualBuiltin: functionCaptureBinding.typeSymbol
                                                            span: syntax.SourceSpan { fileId: functionCaptureNode.sourceModule, start: functionCaptureAst.start, length: functionCaptureAst.length }
                                                        })
                                                    }
                                                }
                                            }
                                        }
                                    }
                                    (functionCaptureNode.kind == 6 and functionCaptureNode.targetModule >= 0 and functionCaptureNode.symbol >= 0) -> if {
                                        -1 => transitiveTargetFunction!
                                        0 => transitiveTargetSearch!
                                        transitiveTargetSearch! < (typed -> len) -> while {
                                            typed[transitiveTargetSearch!] => transitiveTargetCandidate
                                            (transitiveTargetCandidate.kind == 0 and transitiveTargetCandidate.sourceModule == functionCaptureNode.targetModule and transitiveTargetCandidate.symbol == functionCaptureNode.symbol) -> if { transitiveTargetSearch! => transitiveTargetFunction! }
                                            transitiveTargetSearch! + 1 => transitiveTargetSearch!
                                        }
                                        transitiveTargetFunction! >= 0 -> if { pendingCaptureFunctions! -> push(transitiveTargetFunction!) }
                                    }
                                }
                                functionCaptureSearch! + 1 => functionCaptureSearch!
                            }
                        }
                        pendingCaptureFunctionIndex! + 1 => pendingCaptureFunctionIndex!
                    }
                }
            }
        }
        parallelIrIndex! + 1 => parallelIrIndex!
    }
    diagnostics!
}
