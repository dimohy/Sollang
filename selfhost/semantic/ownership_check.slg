            }
            (borrowedTakeSource.kind == 5 and borrowedTakeOwnerBinding >= 0 and borrowedTakeElementIndex! >= 0) -> if {
                0 => borrowedTakeOriginSearch!
                borrowedTakeOriginSearch! < (borrowedBindings! -> len) -> while {
                    borrowedBindings![borrowedTakeOriginSearch!] => borrowedTakeOrigin
                    (borrowedTakeOrigin.ownerBindingIr == borrowedTakeOwnerBinding and (borrowedTakeOrigin.ownerPlaceIr -> placeOverlapsIndexedProjection(borrowedTakeElementIndex!)) and borrowedTakeOrigin.bindingIr < borrowedTakeIndex! and (prepared -> borrowedBindingUsedAfterSite(typed, borrowedTakeOrigin.bindingIr, borrowedTakeIndex!, -1))) -> if {
                        prepared.package.ranges[borrowedTake.sourceModule] => borrowedTakeRange
                        prepared.package.nodes[borrowedTakeRange.astStart + borrowedTake.astNode] => borrowedTakeAst
                        diagnostics! -> push(OwnershipDiagnostic {
                            code: 21
                            sourceModule: borrowedTake.sourceModule
                            functionSymbol: -1
                            expectedOrigin: -1
                            expectedModule: -1
                            expectedSymbol: borrowedTakeOwnerBinding
                            actualOrigin: -1
                            actualModule: -1
                            actualSymbol: borrowedTakeOrigin.bindingIr
                            actualBuiltin: -1
                            span: syntax.SourceSpan { fileId: borrowedTake.sourceModule, start: borrowedTakeAst.start, length: borrowedTakeAst.length }
                        })
                    }
                    borrowedTakeOriginSearch! + 1 => borrowedTakeOriginSearch!
                }
            }
        }
        borrowedTakeIndex! + 1 => borrowedTakeIndex!
    }

    0 => partialMoveIndex!
    partialMoveIndex! < (moves! -> len) -> while {
        moves![partialMoveIndex!] => partialMove
        false => partialMoveIsExplicitExtraction!
        # A member nested inside an aggregate literal may be a shallow,
        # call-scoped request projection. `movesFrom` still retains that event
        # for drop suppression, but E17 becomes production-blocking only for
        # explicit extraction/call/assignment move sites whose ownership
        # context is already canonical.
        (partialMove.memberIr >= 0 and typed[partialMove.siteIr].kind != 13) -> if {
            true => partialMoveIsExplicitExtraction!
            typed[partialMove.siteIr] => partialMoveSite
            prepared.package.ranges[partialMove.sourceModule] => sourceRange
            prepared.package.nodes[sourceRange.astStart + partialMoveSite.astNode].start => partialMoveStart
            0 => movedUseIndex!
            movedUseIndex! < (typed -> len) -> while {
                typed[movedUseIndex!] => movedUse
                (movedUse.kind == 5 and movedUse.sourceModule == partialMove.sourceModule and movedUse.symbol == partialMove.symbol and prepared.package.nodes[sourceRange.astStart + movedUse.astNode].start > partialMoveStart and not (movedUseIndex! -> nodeBelongsTo(partialMove.siteIr))) -> if {
                    movedUse.parent => movedUseAncestor!
                    -1 => movedUseMember!
                    (movedUseAncestor! >= 0 and movedUseMember! < 0) -> while {
                        (typed[movedUseAncestor!].kind == 13 or typed[movedUseAncestor!].kind == 15) -> if { movedUseAncestor! => movedUseMember! } else { typed[movedUseAncestor!].parent => movedUseAncestor! }
                    }
                    movedUseMember! < 0 => invalidMovedUse!
                    movedUseMember! >= 0 -> if {
                        partialMove.memberIr -> placesOverlap(movedUseMember!) => invalidMovedUse!
                    }
                    invalidMovedUse! -> if {
                        false => partialMovePathTerminates!
                        partialMove.siteIr -> moveRegionFor => partialMoveRegion
                        prepared.package.nodes[sourceRange.astStart + movedUse.astNode].start => partialMoveUseStart
                        0 => partialMoveReturnSearch!
                        (not partialMovePathTerminates! and partialMoveReturnSearch! < (typed -> len)) -> while {
                            typed[partialMoveReturnSearch!] => partialMoveReturn
                            (partialMoveReturn.kind == 23 and partialMoveReturn.sourceModule == partialMove.sourceModule and partialMoveReturn.astNode >= 0 and (partialMoveReturnSearch! -> moveRegionFor) == partialMoveRegion) -> if {
                                prepared.package.nodes[sourceRange.astStart + partialMoveReturn.astNode].start => partialMoveReturnStart
                                (partialMoveStart < partialMoveReturnStart and partialMoveReturnStart < partialMoveUseStart) -> if { true => partialMovePathTerminates! }
                            }
                            partialMoveReturnSearch! + 1 => partialMoveReturnSearch!
                        }
                        partialMovePathTerminates! -> if { false => invalidMovedUse! }
                    }
                    (invalidMovedUse! and not (partialMove.siteIr -> useReachableAfterMove(movedUseIndex!))) -> if { false => invalidMovedUse! }
                    (invalidMovedUse! and (partialMoveIndex! -> moveReinitializedBefore(prepared.package.nodes[sourceRange.astStart + movedUse.astNode].start))) -> if { false => invalidMovedUse! }
                    invalidMovedUse! -> if {
                        false => duplicateMoveDiagnostic!
                        0 => moveDiagnosticIndex!
                        moveDiagnosticIndex! < (diagnostics! -> len) -> while {
                            diagnostics![moveDiagnosticIndex!] => existingMoveDiagnostic
                            (existingMoveDiagnostic.code == 17 and existingMoveDiagnostic.span.fileId == partialMove.sourceModule and existingMoveDiagnostic.span.start == prepared.package.nodes[sourceRange.astStart + movedUse.astNode].start) -> if { true => duplicateMoveDiagnostic! }
                            moveDiagnosticIndex! + 1 => moveDiagnosticIndex!
                        }
                        not duplicateMoveDiagnostic! -> if {
                            diagnostics! -> push(OwnershipDiagnostic {
                                code: 17
                                sourceModule: partialMove.sourceModule
                                functionSymbol: -1
                                expectedOrigin: -1
                                expectedModule: -1
                                expectedSymbol: partialMove.siteIr
                                actualOrigin: -1
                                actualModule: -1
                                actualSymbol: movedUseIndex!
                                actualBuiltin: -1
                                span: syntax.SourceSpan { fileId: partialMove.sourceModule, start: prepared.package.nodes[sourceRange.astStart + movedUse.astNode].start, length: prepared.package.nodes[sourceRange.astStart + movedUse.astNode].length }
                            })
