namespace sollang.compiler.semantic.ownership_check

import sollang.compiler.ast as ast
import sollang.compiler.ir.typed as typedIr
import sollang.compiler.lexer as lexer
import sollang.compiler.semantic.context as semanticContext
import sollang.compiler.syntax as syntax
import syntax.generated.slg as grammar

public struct OwnershipDiagnostic {
    code: Int
    sourceModule: Int
    functionSymbol: Int
    expectedOrigin: Int
    expectedModule: Int
    expectedSymbol: Int
    actualOrigin: Int
    actualModule: Int
    actualSymbol: Int
    actualBuiltin: Int
    span: syntax.SourceSpan
}

struct BorrowedTextReturn {
    sourceModule: Int
    functionSymbol: Int
    parameterOrdinal: Int
}

struct BorrowedTextBinding {
    bindingIr: Int
    ownerBindingIr: Int
    ownerPlaceIr: Int
}

struct ReadonlyReferenceReturn {
    sourceModule: Int
    functionSymbol: Int
    parameterOrdinal: Int
}

semanticTypeContainsReadonlyReference prepared: semanticContext.SemanticSnapshot, typeId: Int -> Bool {
    [Int; ~] => pending!
    [Int; ~] => visited!
    false => contains!
    typeId >= 0 -> if { pending! -> push(typeId) }
    0 => pendingIndex!
    (not contains! and pendingIndex! < (pending! -> len)) -> while {
        pending![pendingIndex!] => currentTypeId
        false => seen!
        0 => seenIndex!
        seenIndex! < (visited! -> len) -> while {
            visited![seenIndex!] == currentTypeId -> if { true => seen! }
            seenIndex! + 1 => seenIndex!
        }
        (not seen! and currentTypeId >= 0 and currentTypeId < (prepared.semantic.types -> len)) -> if {
            visited! -> push(currentTypeId)
            prepared.semantic.types[currentTypeId] => currentType
            currentType.kind == 8 -> if {
                true => contains!
            } else {
                currentType.kind == 1 -> if {
                    currentType.module => ownerSourceModule!
                    currentType.origin == 2 -> if {
                        (currentType.module >= 0 and currentType.module < (prepared.modules -> len)) -> if {
                            prepared.modules[currentType.module].sourceIndex => ownerSourceModule!
                        }
                    }
                    -1 => ownerDeclarationAst!
                    (ownerSourceModule! >= 0 and ownerSourceModule! < (prepared.package.ranges -> len)) -> if {
                        prepared.package.ranges[ownerSourceModule!] => ownerRange
                        (currentType.symbol >= 0 and currentType.symbol < ownerRange.symbolCount) -> if {
                            prepared.package.symbols[ownerRange.symbolStart + currentType.symbol] => ownerSymbol
                            ownerSymbol.astNode >= 0 -> if { ownerSymbol.astNode => ownerDeclarationAst! }
                        }
                    }
                    false => ownerIsEnum!
                    ownerDeclarationAst! >= 0 -> if {
                        prepared.package.ranges[ownerSourceModule!] => ownerRange
                        prepared.package.nodes[ownerRange.astStart + ownerDeclarationAst!].kind == 4 -> if { true => ownerIsEnum! }
                    }
                    ownerIsEnum! -> if {
                        0 => payloadReferenceIndex!
                        payloadReferenceIndex! < (prepared.semantic.references -> len) -> while {
                            prepared.semantic.references[payloadReferenceIndex!] => payloadReference
                            (payloadReference.status == 0 and payloadReference.sourceModule == ownerSourceModule! and payloadReference.typeAst >= 0) -> if {
                                payloadReference.typeAst => payloadAncestor!
                                false => payloadBelongs!
                                prepared.package.ranges[ownerSourceModule!] => payloadRange
                                (payloadAncestor! >= 0 and payloadAncestor! < payloadRange.astCount and not payloadBelongs!) -> while {
                                    prepared.package.nodes[payloadRange.astStart + payloadAncestor!] => payloadNode
                                    (payloadNode.kind == 27 and payloadNode.parent == ownerDeclarationAst!) -> if {
                                        true => payloadBelongs!
                                    } else {
                                        payloadNode.parent => payloadAncestor!
                                    }
                                }
                                payloadBelongs! -> if { pending! -> push(payloadReference.typeId) }
                            }
                            payloadReferenceIndex! + 1 => payloadReferenceIndex!
                        }
                    } else {
                        0 => fieldIndex!
                        fieldIndex! < (prepared.semantic.fields -> len) -> while {
                            prepared.semantic.fields[fieldIndex!] => field
                            (field.status == 0 and field.ownerType == currentTypeId) -> if {
                                pending! -> push(field.fieldType)
                            }
                            fieldIndex! + 1 => fieldIndex!
                        }
                    }
                } else {
                    (currentType.kind == 2 or currentType.kind == 3 or currentType.kind == 4 or currentType.kind == 6) -> if {
                        pending! -> push(currentType.first)
                    } else {
                        currentType.kind == 5 -> if {
                            pending! -> push(currentType.first)
                            pending! -> push(currentType.second)
                        }
                    }
                }
            }
        }
        pendingIndex! + 1 => pendingIndex!
    }
    contains!
}

readonlyCarrierUseTouchesReference prepared: semanticContext.SemanticSnapshot, typed: [typedIr.TypedIrNode; ~], useIndex: Int, carrierTypeId: Int -> Bool {
    true => touches!
    (carrierTypeId >= 0 and useIndex >= 0 and useIndex < (typed -> len)) -> if {
        useIndex => projectedUse!
        typed[projectedUse!].parent => projectedParent!
        false => projected!
        (projectedParent! >= 0 and projectedParent! < (typed -> len) and typed[projectedParent!].kind == 13 and typed[projectedParent!].operand0 == projectedUse!) -> while {
            true => projected!
            projectedParent! => projectedUse!
            typed[projectedUse!].parent => projectedParent!
        }
        projected! -> if {
            prepared -> semanticTypeContainsReadonlyReference(typed[projectedUse!].typeId) => touches!
        }
    }
    touches!
}

typedNodeContainsReadonlyReference prepared: semanticContext.SemanticSnapshot, typed: [typedIr.TypedIrNode; ~], nodeIndex: Int -> Bool {
    false => contains!
    (nodeIndex >= 0 and nodeIndex < (typed -> len)) -> if {
        typed[nodeIndex] => candidate
        (candidate.typeId >= 0 and candidate.typeId < (prepared.semantic.types -> len)) -> if {
            prepared -> semanticTypeContainsReadonlyReference(candidate.typeId) => contains!
        } else {
            candidate.typeKind == 1 -> if {
                candidate.typeModule => ownerSourceModule!
                candidate.typeOrigin == 2 -> if {
                    (candidate.typeModule >= 0 and candidate.typeModule < (prepared.modules -> len)) -> if { prepared.modules[candidate.typeModule].sourceIndex => ownerSourceModule! }
                }
                -1 => ownerDeclarationAst!
                (ownerSourceModule! >= 0 and ownerSourceModule! < (prepared.package.ranges -> len)) -> if {
                    prepared.package.ranges[ownerSourceModule!] => ownerRange
                    (candidate.typeSymbol >= 0 and candidate.typeSymbol < ownerRange.symbolCount) -> if {
                        prepared.package.symbols[ownerRange.symbolStart + candidate.typeSymbol] => ownerSymbol
                        ownerSymbol.astNode >= 0 -> if { ownerSymbol.astNode => ownerDeclarationAst! }
                    }
                    (ownerDeclarationAst! >= 0 and prepared.package.nodes[ownerRange.astStart + ownerDeclarationAst!].kind == 4) -> if {
                        0 => payloadReferenceIndex!
                        (not contains! and payloadReferenceIndex! < (prepared.semantic.references -> len)) -> while {
                            prepared.semantic.references[payloadReferenceIndex!] => payloadReference
                            (payloadReference.status == 0 and payloadReference.sourceModule == ownerSourceModule! and payloadReference.typeAst >= 0) -> if {
                                payloadReference.typeAst => payloadAncestor!
                                false => payloadBelongs!
                                (payloadAncestor! >= 0 and payloadAncestor! < ownerRange.astCount and not payloadBelongs!) -> while {
                                    prepared.package.nodes[ownerRange.astStart + payloadAncestor!] => payloadNode
                                    (payloadNode.kind == 27 and payloadNode.parent == ownerDeclarationAst!) -> if { true => payloadBelongs! } else { payloadNode.parent => payloadAncestor! }
                                }
                                (payloadBelongs! and (prepared -> semanticTypeContainsReadonlyReference(payloadReference.typeId))) -> if { true => contains! }
                            }
                            payloadReferenceIndex! + 1 => payloadReferenceIndex!
                        }
                    }
                }
            }
        }
        (not contains! and candidate.kind == 6 and candidate.typeKind == 8) -> if { true => contains! }
        # A collection literal may reach this check before its recursive
        # collection type id is repaired. Inspect its direct element nodes as
        # a fallback; enum constructors and reference-bearing calls already
        # carry their concrete element type ids at this point.
        (not contains! and (candidate.kind == 12 or candidate.kind == 14 or candidate.kind == 16 or candidate.kind == 26 or candidate.typeKind == 5 or (candidate.kind == 6 and candidate.typeKind == 8))) -> if {
            0 => aggregateChildIndex!
            (not contains! and aggregateChildIndex! < (typed -> len)) -> while {
                typed[aggregateChildIndex!].parent == nodeIndex -> if {
                    prepared -> typedNodeContainsReadonlyReference(typed, aggregateChildIndex!) -> if { true => contains! }
                }
                aggregateChildIndex! + 1 => aggregateChildIndex!
            }
        }
    }
    contains!
}

# Code 17 identifies whole-owner or overlapping-field use after a partial move.
# Code 18 identifies a mutable binding captured by a parallel callback.
# Code 19 identifies a structurally non-sendable parallel callback capture.
# Code 20 identifies a branch or loop that exits with a partially moved path.
# Code 21 identifies an origin moved while a returned borrowed Text is live.
# Code 22 identifies a readonly-reference argument without stable storage.
# The view region ends at its last typed-IR use rather than at lexical scope end.
indexAssignmentTargetsBinding prepared: semanticContext.SemanticSnapshot, typed: [typedIr.TypedIrNode; ~], assignmentIr: Int, bindingIr: Int -> Bool {
    false => same!
    (assignmentIr >= 0 and assignmentIr < (typed -> len) and bindingIr >= 0 and bindingIr < (typed -> len)) -> if {
        typed[assignmentIr] => assignment
        typed[bindingIr] => binding
        (assignment.kind == 24 and assignment.sourceModule == binding.sourceModule and assignment.astNode >= 0 and assignment.sourceModule >= 0 and assignment.sourceModule < (prepared.package.ranges -> len)) -> if {
            prepared.package.ranges[assignment.sourceModule] => sourceRange
            (assignment.astNode < sourceRange.astCount and binding.payloadToken >= 0) -> if {
                prepared.package.nodes[sourceRange.astStart + assignment.astNode] => assignmentAst
                (assignmentAst.kind == 53 and assignmentAst.payloadToken >= 0) -> if {
                    prepared.package.tokens[sourceRange.tokenStart + assignmentAst.payloadToken] => assignmentName
                    prepared.package.tokens[sourceRange.tokenStart + binding.payloadToken] => bindingName
                    assignmentName.span.length == bindingName.span.length => same!
                    UIntSize(0) => nameByte!
                    (same! and nameByte! < assignmentName.span.length) -> while {
                        (prepared.package.sources[assignment.sourceModule] -> byte(assignmentName.span.start + nameByte!)) != (prepared.package.sources[binding.sourceModule] -> byte(bindingName.span.start + nameByte!)) -> if { false => same! }
                        nameByte! + UIntSize(1) => nameByte!
                    }
                }
            }
        }
    }
    same!
}

indexedReferenceOverlapsAssignment prepared: semanticContext.SemanticSnapshot, typed: [typedIr.TypedIrNode; ~], placeIr: Int, indexIr: Int -> Bool {
    true => overlap!
    (placeIr >= 0 and placeIr < (typed -> len) and indexIr >= 0 and indexIr < (typed -> len)) -> if {
        placeIr + 0 => indexedPlaceIr!
        (indexedPlaceIr! >= 0 and indexedPlaceIr! < (typed -> len) and typed[indexedPlaceIr!].kind == 13) -> while {
            typed[indexedPlaceIr!].operand0 => indexedPlaceIr!
        }
        typed[indexedPlaceIr!] => place
        (place.kind == 15 and place.operand1 >= 0 and place.operand1 < (typed -> len)) -> if {
            typed[place.operand1] => borrowedIndex
            typed[indexIr] => assignedIndex
            (borrowedIndex.kind == 3 and assignedIndex.kind == 3 and borrowedIndex.payloadToken >= 0 and assignedIndex.payloadToken >= 0) -> if {
                prepared.package.ranges[borrowedIndex.sourceModule] => borrowedRange
                prepared.package.ranges[assignedIndex.sourceModule] => assignedRange
                prepared.package.tokens[borrowedRange.tokenStart + borrowedIndex.payloadToken] => borrowedToken
                prepared.package.tokens[assignedRange.tokenStart + assignedIndex.payloadToken] => assignedToken
                borrowedToken.span.length == assignedToken.span.length => overlap!
                UIntSize(0) => indexByte!
                (overlap! and indexByte! < borrowedToken.span.length) -> while {
                    (prepared.package.sources[borrowedIndex.sourceModule] -> byte(borrowedToken.span.start + indexByte!)) != (prepared.package.sources[assignedIndex.sourceModule] -> byte(assignedToken.span.start + indexByte!)) -> if { false => overlap! }
                    indexByte! + UIntSize(1) => indexByte!
                }
            }
        }
    }
    overlap!
}

referenceBindingUsedAfterIndexSite prepared: semanticContext.SemanticSnapshot, typed: [typedIr.TypedIrNode; ~], bindingIr: Int, siteIr: Int -> Bool {
    false => used!
    (bindingIr >= 0 and siteIr >= 0 and siteIr < (typed -> len)) -> if {
        typed[siteIr] => site
        (site.sourceModule >= 0 and site.sourceModule < (prepared.package.ranges -> len) and site.astNode >= 0) -> if {
            prepared.package.ranges[site.sourceModule] => useRange
            site.astNode < useRange.astCount -> if {
                prepared.package.nodes[useRange.astStart + site.astNode].start => siteStart
                0 => useIndex!
                (not used! and useIndex! < (typed -> len)) -> while {
                    typed[useIndex!] => use
                    (use.kind == 5 and use.sourceModule == site.sourceModule and use.astNode >= 0 and use.astNode < useRange.astCount and use.operand0 == bindingIr) -> if {
                        prepared.package.nodes[useRange.astStart + use.astNode].start > siteStart -> if { true => used! }
                    }
                    useIndex! + 1 => useIndex!
                }
            }
        }
    }
    used!
}

referenceForwardUseReachable prepared: semanticContext.SemanticSnapshot, typed: [typedIr.TypedIrNode; ~], moveIndex: Int, useIndex: Int -> Bool {
    false => exclusive!
    moveIndex => moveAncestor!
    (moveAncestor! >= 0 and moveAncestor! < (typed -> len) and not exclusive!) -> while {
        typed[moveAncestor!] => moveAncestorNode
        moveAncestorNode.kind == 19 -> if {
            moveAncestorNode.parent >= 0 -> if {
                moveAncestorNode.parent < (typed -> len) -> if {
                    (typed[moveAncestorNode.parent].kind == 18 or typed[moveAncestorNode.parent].kind == 27) -> if {
                        useIndex => useAncestor!
                        (useAncestor! >= 0 and useAncestor! < (typed -> len) and typed[useAncestor!].parent != moveAncestorNode.parent) -> while {
                            typed[useAncestor!].parent => useAncestor!
                        }
                        (useAncestor! >= 0 and useAncestor! < (typed -> len) and useAncestor! != moveAncestor! and typed[useAncestor!].kind == 19) -> if {
                            true => exclusive!
                        }
                    }
                }
            }
            (not exclusive! and moveAncestorNode.sourceModule >= 0 and moveAncestorNode.sourceModule < (prepared.package.ranges -> len) and moveAncestorNode.astNode >= 0) -> if {
                prepared.package.ranges[moveAncestorNode.sourceModule] => moveAncestorRange
                moveAncestorNode.astNode < moveAncestorRange.astCount -> if {
                    prepared.package.nodes[moveAncestorRange.astStart + moveAncestorNode.astNode].kind == 58 -> if {
                        moveAncestorNode.nextOperand => nextAlternative!
                        (nextAlternative! >= 0 and nextAlternative! < (typed -> len)) -> if {
                            useIndex => alternativeUseAncestor!
                            false => useInAlternative!
                            (alternativeUseAncestor! >= 0 and alternativeUseAncestor! < (typed -> len) and not useInAlternative!) -> while {
                                alternativeUseAncestor! == nextAlternative! -> if {
                                    true => useInAlternative!
                                } else {
                                    typed[alternativeUseAncestor!].parent => alternativeUseAncestor!
                                }
                            }
                            useInAlternative! -> if { true => exclusive! }
                        }
                    }
                }
            }
        }
        moveAncestorNode.parent => moveAncestor!
    }
    exclusive! -> if {
        false
    } else {
        moveIndex => moveRegion!
        (moveRegion! >= 0 and moveRegion! < (typed -> len) and typed[moveRegion!].kind != 19 and typed[moveRegion!].kind != 20) -> while {
            typed[moveRegion!].parent => moveRegion!
        }
        prepared.package.ranges[typed[moveIndex].sourceModule] => reachabilityRange
        prepared.package.nodes[reachabilityRange.astStart + typed[moveIndex].astNode].start => moveStart
        prepared.package.nodes[reachabilityRange.astStart + typed[useIndex].astNode].start => useStart
        false => stopped!
        0 => exitIndex!
        (not stopped! and exitIndex! < (typed -> len)) -> while {
            typed[exitIndex!] => exitCandidate
            (exitCandidate.sourceModule == typed[moveIndex].sourceModule and exitCandidate.astNode >= 0 and (exitCandidate.kind == 23 or (exitCandidate.kind == 21 and exitCandidate.opcode == 0))) -> if {
                exitIndex! => exitRegion!
                (exitRegion! >= 0 and exitRegion! < (typed -> len) and typed[exitRegion!].kind != 19 and typed[exitRegion!].kind != 20) -> while {
                    typed[exitRegion!].parent => exitRegion!
                }
                exitRegion! == moveRegion! -> if {
                    prepared.package.nodes[reachabilityRange.astStart + exitCandidate.astNode].start => exitStart
                    (moveStart < exitStart and exitStart < useStart) -> if { true => stopped! }
                }
            }
            exitIndex! + 1 => exitIndex!
        }
        not stopped!
    }
}

public analyze sources: [Text; ~] -> [OwnershipDiagnostic; ~] {
    sources -> semanticContext.prepare => prepared
    prepared -> analyzeContext
}

public analyzeContext prepared: semanticContext.SemanticSnapshot -> [OwnershipDiagnostic; ~] {
    prepared -> typedIr.lowerContext => typed
    prepared -> analyzeLoweredContext(typed)
}

# Ownership is a read-only consumer of the canonical typed IR. The compiler
# driver lowers once and shares the same value with validation and LLVM output.
public analyzeLoweredContext prepared: semanticContext.SemanticSnapshot, typed: [typedIr.TypedIrNode; ~] -> [OwnershipDiagnostic; ~] {
    moveRegionFor nodeIndex: Int -> Int {
        typed[nodeIndex].parent => region!
        (region! >= 0 and typed[region!].kind != 1 and typed[region!].kind != 11 and typed[region!].kind != 19 and typed[region!].kind != 20) -> while {
            typed[region!].parent => region!
        }
        region!
    }
    nodeBelongsTo nodeIndex: Int, ancestorIndex: Int -> Bool {
        nodeIndex => ancestor!
        false => belongs!
        (ancestor! >= 0 and not belongs!) -> while {
            ancestor! == ancestorIndex -> if {
                true => belongs!
            } else {
                typed[ancestor!].parent => ancestor!
            }
        }
        belongs!
    }
    # Structured parallel callbacks borrow captures and join before the parent
    # resumes. SourceText is an immutable shared view here (Sync-like), not an
    # async ownership transfer (Send-like). Other affine runtime owners remain
    # rejected, including Arena, Arguments, and mapped byte views.
    captureBindingIsParallelShareable bindingIndex: Int -> Bool {
        typed[bindingIndex] => binding
        [Int; ~] => pendingTypes!
        [Int; ~] => visitedTypes!
        true => shareable!
        binding.typeId >= 0 -> if {
            pendingTypes! -> push(binding.typeId)
        } else {
            (binding.typeOrigin == 1 and (binding.typeSymbol == 15 or binding.typeSymbol == 16 or binding.typeSymbol == 17 or binding.typeSymbol == 18)) -> if { false => shareable! }
        }
        0 => pendingTypeIndex!
        (shareable! and pendingTypeIndex! < (pendingTypes! -> len)) -> while {
            pendingTypes![pendingTypeIndex!] => pendingTypeId
            false => typeVisited!
            0 => visitedTypeIndex!
            visitedTypeIndex! < (visitedTypes! -> len) -> while {
                visitedTypes![visitedTypeIndex!] == pendingTypeId -> if { true => typeVisited! }
                visitedTypeIndex! + 1 => visitedTypeIndex!
            }
            not typeVisited! -> if {
                visitedTypes! -> push(pendingTypeId)
                (pendingTypeId < 0 or pendingTypeId >= (prepared.semantic.types -> len)) -> if {
                    false => shareable!
                } else {
                    prepared.semantic.types[pendingTypeId] => pendingType
                    pendingType.status != 0 -> if { false => shareable! } else {
                        pendingType.kind == 1 -> if {
                            pendingType.origin == 1 -> if {
                                (pendingType.symbol == 15 or pendingType.symbol == 16 or pendingType.symbol == 17 or pendingType.symbol == 18) -> if { false => shareable! }
                            } else {
                                (pendingType.origin == 0 or pendingType.origin == 2) -> if {
                                    0 => fieldIndex!
                                    fieldIndex! < (prepared.semantic.fields -> len) -> while {
                                        prepared.semantic.fields[fieldIndex!] => field
                                        (field.status == 0 and field.ownerType == pendingTypeId) -> if { pendingTypes! -> push(field.fieldType) }
                                        fieldIndex! + 1 => fieldIndex!
                                    }
                                } else { false => shareable! }
                            }
                        } else {
                            (pendingType.kind == 2 or pendingType.kind == 3 or pendingType.kind == 4 or pendingType.kind == 6 or pendingType.kind == 8) -> if {
                                pendingTypes! -> push(pendingType.first)
                            } else {
                                pendingType.kind == 5 -> if {
                                    pendingTypes! -> push(pendingType.first)
                                    pendingTypes! -> push(pendingType.second)
                                } else {
                                    pendingType.kind == 7 -> if {
                                        pendingType.first >= 0 -> if { pendingTypes! -> push(pendingType.first) }
                                        pendingType.second >= 0 -> if { pendingTypes! -> push(pendingType.second) }
                                    } else { false => shareable! }
                                }
                            }
                        }
                    }
                }
            }
            pendingTypeIndex! + 1 => pendingTypeIndex!
        }
        shareable!
    }
    sameBindingName leftIndex: Int, rightIndex: Int -> Bool {
        typed[leftIndex] => left
        typed[rightIndex] => right
        false => same!
        (left.sourceModule == right.sourceModule and left.payloadToken >= 0 and right.payloadToken >= 0) -> if {
            prepared.package.ranges[left.sourceModule] => nameRange
            prepared.package.tokens[nameRange.tokenStart + left.payloadToken] => leftName
            prepared.package.tokens[nameRange.tokenStart + right.payloadToken] => rightName
            leftName.span.length == rightName.span.length => same!
            UIntSize(0) => nameByte!
            (same! and nameByte! < leftName.span.length) -> while {
                (prepared.package.sources[left.sourceModule] -> byte(leftName.span.start + nameByte!)) != (prepared.package.sources[right.sourceModule] -> byte(rightName.span.start + nameByte!)) -> if {
                    false => same!
                }
                nameByte! + UIntSize(1) => nameByte!
            }
        }
        same!
    }
    placeRootBinding placeIr: Int -> Int {
        placeIr => root!
        (root! >= 0 and (typed[root!].kind == 13 or typed[root!].kind == 15)) -> while {
            typed[root!].operand0 => root!
        }
        (root! >= 0 and typed[root!].kind == 5 and typed[root!].operand0 >= 0) -> if {
            typed[root!].operand0
        } else { -1 }
    }
    placeProjectionDepth placeIr: Int -> Int {
        placeIr => projected!
        0 => depth!
        (projected! >= 0 and (typed[projected!].kind == 13 or typed[projected!].kind == 15)) -> while {
            depth! + 1 => depth!
            typed[projected!].operand0 => projected!
        }
        depth!
    }
    placeProjectionAt placeIr: Int, ordinal: Int -> Int {
        placeIr -> placeProjectionDepth => depth
        placeIr => projected!
        depth - 1 => currentOrdinal!
        (projected! >= 0 and currentOrdinal! > ordinal) -> while {
            typed[projected!].operand0 => projected!
            currentOrdinal! - 1 => currentOrdinal!
        }
        projected!
    }
    tokenTextEquals leftModule: Int, leftToken: Int, rightModule: Int, rightToken: Int -> Bool {
        false => same!
        (leftModule >= 0 and rightModule >= 0 and leftToken >= 0 and rightToken >= 0) -> if {
            prepared.package.ranges[leftModule] => leftRange
            prepared.package.ranges[rightModule] => rightRange
            prepared.package.tokens[leftRange.tokenStart + leftToken] => left
            prepared.package.tokens[rightRange.tokenStart + rightToken] => right
            left.span.length == right.span.length => same!
            UIntSize(0) => byteIndex!
            (same! and byteIndex! < left.span.length) -> while {
                (prepared.package.sources[leftModule] -> byte(left.span.start + byteIndex!)) != (prepared.package.sources[rightModule] -> byte(right.span.start + byteIndex!)) -> if {
                    false => same!
                }
                byteIndex! + UIntSize(1) => byteIndex!
            }
        }
        same!
    }
    referencePlaceOverlapsMemberAssignment placeIr: Int, assignmentIr: Int -> Bool {
        placeIr -> placeProjectionDepth => depth
        true => overlap!
        depth > 0 -> if {
            placeIr -> placeProjectionAt(0) => firstProjectionIr
            typed[firstProjectionIr] => firstProjection
            firstProjection.kind == 13 -> if {
                prepared.package.ranges[firstProjection.sourceModule] => projectionRange
                prepared.package.nodes[projectionRange.astStart + firstProjection.astNode] => projectionAst
                typed[firstProjection.operand0] => projectionBase
                prepared.package.nodes[projectionRange.astStart + projectionBase.astNode] => projectionBaseAst
                projectionBaseAst.start + projectionBaseAst.length => projectionBaseEnd
                -1 => projectionFieldToken!
                projectionAst.firstToken => projectionTokenIndex!
                (projectionFieldToken! < 0 and projectionTokenIndex! < projectionAst.firstToken + projectionAst.tokenCount) -> while {
                    prepared.package.tokens[projectionRange.tokenStart + projectionTokenIndex!] => projectionToken
                    (projectionToken.span.start >= projectionBaseEnd and projectionToken.kind == grammar.tokenIdIdentifier) -> if {
                        projectionTokenIndex! => projectionFieldToken!
                    }
                    projectionTokenIndex! + 1 => projectionTokenIndex!
                }
                prepared.package.ranges[typed[assignmentIr].sourceModule] => assignmentRange
                prepared.package.nodes[assignmentRange.astStart + typed[assignmentIr].astNode] => assignmentAst
                (projectionFieldToken! >= 0 and assignmentAst.secondaryToken >= 0) -> if {
                    prepared.package.tokens[projectionRange.tokenStart + projectionFieldToken!] => projectionField
                    prepared.package.tokens[assignmentRange.tokenStart + assignmentAst.secondaryToken] => assignmentField
                    projectionField.span.length == assignmentField.span.length => overlap!
                    UIntSize(0) => fieldByte!
                    (overlap! and fieldByte! < projectionField.span.length) -> while {
                        (prepared.package.sources[firstProjection.sourceModule] -> byte(projectionField.span.start + fieldByte!)) != (prepared.package.sources[typed[assignmentIr].sourceModule] -> byte(assignmentField.span.start + fieldByte!)) -> if {
                            false => overlap!
                        }
                        fieldByte! + UIntSize(1) => fieldByte!
                    }
                }
            }
        }
