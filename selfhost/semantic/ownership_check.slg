                                            typed[functionCaptureBindingIndex!] => functionCaptureBinding
                                            functionCaptureBinding.flags == 1 -> if {
                                                false => functionMutableReported!
                                                0 => functionReportedIndex!
                                                functionReportedIndex! < (reportedMutableCaptures! -> len) -> while {
                                                    reportedMutableCaptures![functionReportedIndex!] == functionCaptureBindingIndex! -> if { true => functionMutableReported! }
                                                    functionReportedIndex! + 1 => functionReportedIndex!
                                                }
                                                not functionMutableReported! -> if {
                                                    reportedMutableCaptures! -> push(functionCaptureBindingIndex!)
                                                    prepared.package.ranges[functionCaptureNode.sourceModule] => functionCaptureRange
                                                    prepared.package.nodes[functionCaptureRange.astStart + functionCaptureNode.astNode] => functionCaptureAst
                                                    diagnostics! -> push(OwnershipDiagnostic {
                                                        code: 18
                                                        sourceModule: functionCaptureNode.sourceModule
                                                        functionSymbol: typed[captureFunctionIr].symbol
                                                        expectedOrigin: -1
                                                        expectedModule: -1
                                                        expectedSymbol: -1
                                                        actualOrigin: functionCaptureBinding.typeOrigin
                                                        actualModule: functionCaptureBinding.typeModule
                                                        actualSymbol: functionCaptureBinding.typeSymbol
                                                        actualBuiltin: functionCaptureBinding.typeSymbol
                                                        span: syntax.SourceSpan { fileId: functionCaptureNode.sourceModule, start: functionCaptureAst.start, length: functionCaptureAst.length }
                                                    })
                                                }
                                            } else {
