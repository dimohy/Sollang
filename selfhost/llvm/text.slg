    emitDirectoryCall request: DirectoryCallRequest -> Unit uses Console {
        context.ir[request.callIndex] => call
        request.callIndex -> callArgumentIndex => argumentIndex!
        argumentIndex! -> aggregateValueIndex => argumentIndex!
        context.ir[argumentIndex!] => directoryPath
        -1 => pathBytesType!
        -1 => pathStyleType!
        0 => pathFieldIndex!
        pathFieldIndex! < (context.fields -> len) -> while {
            context.fields[pathFieldIndex!] => pathField
            (pathField.status == 0 and pathField.ownerType == directoryPath.typeId and pathField.ordinal == 0) -> if { pathField.fieldType => pathBytesType! }
            (pathField.status == 0 and pathField.ownerType == directoryPath.typeId and pathField.ordinal == 1) -> if { pathField.fieldType => pathStyleType! }
            pathFieldIndex! + 1 => pathFieldIndex!
        }
        "  %v$(request.callIndex)_directory_path_bytes = extractvalue " -> print
        directoryPath -> writeIrType
        " " -> print
        (directoryPath.kind == 5 and request.ownerIndex >= 0 and context.ir[request.ownerIndex].operand1 >= 0 and directoryPath.symbol == context.ir[context.ir[request.ownerIndex].operand1].symbol) -> if { "%arg" -> print } else { "%v$(argumentIndex!)" -> print }
        ", 0" -> println
        "  %v$(request.callIndex)_directory_path_data = extractvalue " -> print
        pathBytesType! -> writeSemanticTypeId
        " %v$(request.callIndex)_directory_path_bytes, 0" -> println
        "  %v$(request.callIndex)_directory_path_length = extractvalue " -> print
        pathBytesType! -> writeSemanticTypeId
        " %v$(request.callIndex)_directory_path_bytes, 1" -> println
        "  %v$(request.callIndex)_directory_path_style_value = extractvalue " -> print
        directoryPath -> writeIrType
        " " -> print
        (directoryPath.kind == 5 and request.ownerIndex >= 0 and context.ir[request.ownerIndex].operand1 >= 0 and directoryPath.symbol == context.ir[context.ir[request.ownerIndex].operand1].symbol) -> if { "%arg" -> print } else { "%v$(argumentIndex!)" -> print }
        ", 1" -> println
        "  %v$(request.callIndex)_directory_path_style = extractvalue " -> print
        pathStyleType! -> writeSemanticTypeId
        " %v$(request.callIndex)_directory_path_style_value, 0" -> println
        "  %v$(request.callIndex)_directory_raw = call %sollang.directory_result @sollang_platform_read_directory(ptr %v$(request.callIndex)_directory_path_data, i64 %v$(request.callIndex)_directory_path_length, i32 %v$(request.callIndex)_directory_path_style)" -> println
        "  %v$(request.callIndex)_directory_data = extractvalue %sollang.directory_result %v$(request.callIndex)_directory_raw, 0" -> println
        "  %v$(request.callIndex)_directory_length = extractvalue %sollang.directory_result %v$(request.callIndex)_directory_raw, 1" -> println
        "  %v$(request.callIndex)_directory_count = extractvalue %sollang.directory_result %v$(request.callIndex)_directory_raw, 2" -> println
        "  %v$(request.callIndex)_directory_status = extractvalue %sollang.directory_result %v$(request.callIndex)_directory_raw, 3" -> println
        "  %v$(request.callIndex)_directory_ok = icmp sgt i32 %v$(request.callIndex)_directory_status, 0" -> println
        context.types[call.typeId] => resultType
        resultType.first => rawTypeId!
        call.typeId -> isNominalEnumType -> if {
            call.typeId -> enumPayloadTypes => directoryResultPayloads!
            (directoryResultPayloads! -> len) > 0 -> if { directoryResultPayloads![0] => rawTypeId! }
        }
        -1 => rawBytesType!
        0 => rawFieldIndex!
        rawFieldIndex! < (context.fields -> len) -> while {
            context.fields[rawFieldIndex!] => rawField
            (rawField.status == 0 and rawField.ownerType == rawTypeId! and rawField.ordinal == 0) -> if { rawField.fieldType => rawBytesType! }
            rawFieldIndex! + 1 => rawFieldIndex!
        }
        "  %v$(request.callIndex)_directory_result_slot = alloca " -> print
        call -> writeIrType
        ", align 8" -> println
        "  store " -> print
        call -> writeIrType
        " zeroinitializer, ptr %v$(request.callIndex)_directory_result_slot, align 8" -> println
        "  br i1 %v$(request.callIndex)_directory_ok, label %directory$(request.callIndex)_ok, label %directory$(request.callIndex)_error" -> println
        "directory$(request.callIndex)_ok:" -> println
        "  %v$(request.callIndex)_directory_bytes0 = insertvalue " -> print
        rawBytesType! -> writeSemanticTypeId
        " poison, ptr %v$(request.callIndex)_directory_data, 0" -> println
        "  %v$(request.callIndex)_directory_bytes1 = insertvalue " -> print
        rawBytesType! -> writeSemanticTypeId
        " %v$(request.callIndex)_directory_bytes0, i64 %v$(request.callIndex)_directory_length, 1" -> println
        "  %v$(request.callIndex)_directory_bytes = insertvalue " -> print
        rawBytesType! -> writeSemanticTypeId
        " %v$(request.callIndex)_directory_bytes1, i64 %v$(request.callIndex)_directory_length, 2" -> println
        "  %v$(request.callIndex)_directory_raw0 = insertvalue " -> print
        rawTypeId! -> writeSemanticTypeId
        " poison, " -> print
        rawBytesType! -> writeSemanticTypeId
        " %v$(request.callIndex)_directory_bytes, 0" -> println
        "  %v$(request.callIndex)_directory_raw_value = insertvalue " -> print
        rawTypeId! -> writeSemanticTypeId
        " %v$(request.callIndex)_directory_raw0, i64 %v$(request.callIndex)_directory_count, 1" -> println
        "  %v$(request.callIndex)_directory_ok_tag = getelementptr inbounds " -> print
        call -> writeIrType
        ", ptr %v$(request.callIndex)_directory_result_slot, i32 0, i32 0" -> println
        "  store i32 0, ptr %v$(request.callIndex)_directory_ok_tag, align 4" -> println
        "  %v$(request.callIndex)_directory_ok_payload = getelementptr inbounds " -> print
        call -> writeIrType
        ", ptr %v$(request.callIndex)_directory_result_slot, i32 0, i32 1" -> println
        "  store " -> print
        rawTypeId! -> writeSemanticTypeId
        " %v$(request.callIndex)_directory_raw_value, ptr %v$(request.callIndex)_directory_ok_payload, align 8" -> println
        "  br label %directory$(request.callIndex)_merge" -> println
        "directory$(request.callIndex)_error:" -> println
        "  %v$(request.callIndex)_directory_error_tag = getelementptr inbounds " -> print
        call -> writeIrType
        ", ptr %v$(request.callIndex)_directory_result_slot, i32 0, i32 0" -> println
        "  store i32 1, ptr %v$(request.callIndex)_directory_error_tag, align 4" -> println
        "  %v$(request.callIndex)_directory_error_text0 = insertvalue %sollang.text poison, ptr @sollang_directory_error_io, 0" -> println
        "  %v$(request.callIndex)_directory_error_text = insertvalue %sollang.text %v$(request.callIndex)_directory_error_text0, i64 2, 1" -> println
        "  %v$(request.callIndex)_directory_error_payload = getelementptr inbounds " -> print
        call -> writeIrType
        ", ptr %v$(request.callIndex)_directory_result_slot, i32 0, i32 1" -> println
        "  store %sollang.text %v$(request.callIndex)_directory_error_text, ptr %v$(request.callIndex)_directory_error_payload, align 8" -> println
        "  br label %directory$(request.callIndex)_merge" -> println
        "directory$(request.callIndex)_merge:" -> println
        "  %v$(request.callIndex) = load " -> print
        call -> writeIrType
        ", ptr %v$(request.callIndex)_directory_result_slot, align 8" -> println
    }
    emitTryParallelCollect request: TryParallelCollectRequest -> Unit uses Console {
        context.types[request.callbackTypeId] => callbackResultType
        callbackResultType.first => okTypeId
        callbackResultType.second => errorTypeId
        context.typeSizes[request.callbackTypeId] => callbackStride
        context.typeSizes[okTypeId] => okStride
        context.typeAligns[request.callbackTypeId] => callbackAlign
        context.typeAligns[errorTypeId] => errorAlign
        context.typeAligns[okTypeId] => okAlign
        "  %v$(request.expressionIndex)_failure_limit = load atomic i64, ptr %v$(request.expressionIndex)_failure_limit_slot acquire, align 8" -> println
        "  %v$(request.expressionIndex)_has_failure = icmp ult i64 %v$(request.expressionIndex)_failure_limit, %v$(request.expressionIndex)_length" -> println
        "  br i1 %v$(request.expressionIndex)_has_failure, label %tryparallel$(request.expressionIndex)_error, label %tryparallel$(request.expressionIndex)_success" -> println
        "tryparallel$(request.expressionIndex)_error:" -> println
