import sollang.compiler.llvm.text as llvm
import sys.process as process

main {
    [Text; ~] => sources!
    UIntSize(1) => index!
    index! < (process.arguments -> len) -> while {
        sources! -> push((process.arguments)[index!])
        index! + UIntSize(1) => index!
    }
    sources! -> llvm.emitWasmChecked => diagnosticCount
    diagnosticCount > 0 -> if {
        "; sollang browser compilation failed with $diagnosticCount diagnostic(s)" -> println
    }
}
